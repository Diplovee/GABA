---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const categories = [
  { name: 'Electronics', slug: 'electronics', icon: '💻' },
  { name: 'Clothing', slug: 'clothing', icon: '👕' },
  { name: 'Food & Beverages', slug: 'food', icon: '🍔' },
  { name: 'Services', slug: 'services', icon: '🔧' },
  { name: 'Art & Crafts', slug: 'art', icon: '🎨' },
  { name: 'Health & Beauty', slug: 'health', icon: '💊' },
  { name: 'Education', slug: 'education', icon: '📚' },
  { name: 'Home & Garden', slug: 'home', icon: '🏠' },
  { name: 'Other', slug: 'other', icon: '📦' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Products | GABA" description="Shop products from local Zimbabwean businesses" />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Products</h1>
				<p>Shop from local Zimbabwean businesses</p>
			</section>

			<div class="search-section">
				<input type="text" id="search" placeholder="Search products..." />
			</div>

			<div class="categories">
				<button class="category-btn active" data-category="all">All</button>
				{categories.map((cat) => (
					<button class="category-btn" data-category={cat.slug}>
						<span class="cat-icon">{cat.icon}</span>
						{cat.name}
					</button>
				))}
			</div>

			<section class="products-grid" id="products-grid">
				<div class="loading">Loading products...</div>
			</section>

			<section class="vendor-cta">
				<div class="cta-content">
					<h2>Are you a business?</h2>
					<p>List your products on GABA and reach more customers.</p>
					<a href="/vendor" class="btn-primary">Become a Vendor</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1000px;
		margin: 0 auto;
		padding: 1em;
	}
	.hero {
		text-align: center;
		padding: 3em 0 2em;
	}
	.hero h1 {
		font-size: 2.5em;
		color: var(--zim-green);
		margin-bottom: 0.5em;
	}
	.hero p {
		color: rgb(var(--gray));
	}
	.search-section {
		max-width: 500px;
		margin: 0 auto 2em;
	}
	.search-section input {
		width: 100%;
		padding: 1em;
		border: 2px solid rgb(var(--gray-light));
		border-radius: 8px;
		font-size: 1em;
	}
	.search-section input:focus {
		outline: none;
		border-color: var(--zim-green);
	}
	.categories {
		display: flex;
		gap: 0.75em;
		justify-content: center;
		flex-wrap: wrap;
		margin-bottom: 2em;
	}
	.category-btn {
		display: flex;
		align-items: center;
		gap: 0.5em;
		padding: 0.5em 1em;
		border: 2px solid var(--zim-green);
		background: transparent;
		color: var(--zim-green);
		border-radius: 25px;
		cursor: pointer;
		font-weight: 600;
		font-size: 0.9em;
		transition: all 0.2s;
	}
	.category-btn:hover,
	.category-btn.active {
		background: var(--zim-green);
		color: white;
	}
	.cat-icon {
		font-size: 1.2em;
	}
	.products-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
		gap: 1.5em;
		margin-bottom: 3em;
	}
	.product-card {
		background: white;
		border-radius: 12px;
		overflow: hidden;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
		transition: transform 0.2s, box-shadow 0.2s;
	}
	.product-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
	}
	.product-card.hidden {
		display: none;
	}
	.product-image {
		width: 100%;
		height: 180px;
		background: linear-gradient(135deg, var(--zim-green), var(--zim-gold));
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 3em;
	}
	.product-info {
		padding: 1em;
	}
	.category-badge {
		display: inline-block;
		padding: 0.2em 0.5em;
		background: var(--zim-gold);
		color: black;
		border-radius: 4px;
		font-size: 0.7em;
		font-weight: 600;
		text-transform: uppercase;
		margin-bottom: 0.5em;
	}
	.product-info h3 {
		margin: 0 0 0.5em 0;
		font-size: 1.1em;
	}
	.product-info p {
		color: rgb(var(--gray));
		font-size: 0.9em;
		margin-bottom: 0.5em;
	}
	.price {
		font-size: 1.25em;
		font-weight: bold;
		color: var(--zim-green);
	}
	.loading, .empty-state {
		grid-column: 1 / -1;
		text-align: center;
		padding: 3em;
		color: rgb(var(--gray));
	}
	.vendor-cta {
		background: linear-gradient(135deg, var(--zim-green), #2d7a38);
		border-radius: 16px;
		padding: 3em;
		text-align: center;
		color: white;
		margin-top: 2em;
	}
	.cta-content h2 {
		color: white;
		margin-bottom: 0.5em;
	}
	.cta-content p {
		margin-bottom: 1.5em;
		opacity: 0.9;
	}
	.btn-primary {
		padding: 0.75em 2em;
		background: var(--zim-gold);
		color: black;
		text-decoration: none;
		border-radius: 8px;
		font-weight: 600;
	}
	.btn-primary:hover {
		background: white;
	}
</style>

<script>
	const searchInput = document.getElementById('search') as HTMLInputElement;
	const categoryBtns = document.querySelectorAll('.category-btn');
	const productsGrid = document.getElementById('products-grid');

	let allProducts: any[] = [];

	const sampleProducts = [
		{ _id: '1', name: 'Wireless Headphones', description: 'Premium Bluetooth headphones with noise cancellation', price: 45, category: 'electronics', images: [], status: 'active' },
		{ _id: '2', name: 'Handmade Beaded Necklace', description: 'Traditional Zimbabwean beaded jewelry', price: 25, category: 'art', images: [], status: 'active' },
		{ _id: '3', name: 'Organic Honey', description: 'Pure local honey from rural Zimbabwe', price: 12, category: 'food', images: [], status: 'active' },
		{ _id: '4', name: 'Tailoring Service', description: 'Custom clothing design and alterations', price: 30, category: 'services', images: [], status: 'active' },
	];

	async function loadProducts() {
		try {
			const response = await fetch('/api/products');
			allProducts = await response.json();
		} catch (e) {
			allProducts = sampleProducts;
		}
		renderProducts();
	}

	function renderProducts() {
		if (!productsGrid) return;
		
		const activeCategory = document.querySelector('.category-btn.active')?.getAttribute('data-category');
		const searchTerm = searchInput?.value.toLowerCase() || '';
		
		const filtered = allProducts.filter(p => {
			const matchesCategory = activeCategory === 'all' || p.category === activeCategory;
			const matchesSearch = p.name.toLowerCase().includes(searchTerm) || p.description.toLowerCase().includes(searchTerm);
			return matchesCategory && matchesSearch && p.status === 'active';
		});

		if (filtered.length === 0) {
			productsGrid.innerHTML = '<div class="empty-state">No products found. Be the first to list!</div>';
			return;
		}

		productsGrid.innerHTML = filtered.map(p => `
			<a href="/products/${p._id}" class="product-card">
				<div class="product-image">📦</div>
				<div class="product-info">
					<span class="category-badge">${p.category}</span>
					<h3>${p.name}</h3>
					<p>${p.description}</p>
					<span class="price">$${p.price}</span>
				</div>
			</a>
		`).join('');
	}

	searchInput?.addEventListener('input', renderProducts);

	categoryBtns.forEach(btn => {
		btn.addEventListener('click', () => {
			categoryBtns.forEach(b => b.classList.remove('active'));
			btn.classList.add('active');
			renderProducts();
		});
	});

	loadProducts();
</script>