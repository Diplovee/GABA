---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: project,
	}));
}

const project = Astro.props;
const { Content } = await render(project);

const categoryLabels: Record<string, string> = {
	webapp: 'Web App',
	mobile: 'Mobile App',
	website: 'Website',
};

const slugSeed = project.id.replace(/[^a-z0-9]/gi, '').slice(0, 6).toUpperCase() || 'GABA';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={project.data.title} description={project.data.description} />
	</head>
	<body>
		<Header />
		<main class="product-page">
			<section class="hero-band">
				<div class="hero-main">
					<div class="product-topline">
						<span class="category-badge">{categoryLabels[project.data.category] || project.data.category}</span>
					</div>
					<h1>{project.data.title}</h1>
					<p class="tagline">{project.data.description}</p>
					<p class="support-line">What problem does this solve, for who, and where?</p>
					<div class="hero-actions">
						{project.data.url && <a href={project.data.url} target="_blank" rel="noreferrer" class="btn-primary">Visit website</a>}
						{project.data.repo && <a href={project.data.repo} target="_blank" rel="noreferrer" class="btn-secondary">Source code</a>}
					</div>
				</div>

				<div class="meta-strip">
					<div class="meta-row">
						<span>Country</span>
						<strong>Zimbabwe</strong>
					</div>
					<div class="meta-row">
						<span>Launch ID</span>
						<strong class="mono">ZW-{slugSeed}</strong>
					</div>
					<div class="meta-row">
						<span>Published</span>
						<strong>{project.data.pubDate.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })}</strong>
					</div>
					<div class="meta-row">
						<span>GABA line</span>
						<strong>Built by the left out, for the left out.</strong>
					</div>
				</div>
			</section>

			<section class="visual-band">
				<div class="visual-frame">
					{project.data.heroImage ? (
						<img src={project.data.heroImage.src} alt={project.data.title} />
					) : (
						<div class="visual-placeholder">
							<div class="mark">G</div>
							<div>
								<p>Screen not provided</p>
								<span>Use screenshots or a hero image when available.</span>
							</div>
						</div>
					)}
				</div>
			</section>

			<section class="detail-grid">
				<section class="detail-main">
					<h2>What it does</h2>
					<div class="prose">
						<Content />
					</div>
				</section>

				<aside class="detail-side">
					<div class="detail-row">
						<span>Category</span>
						<strong>{categoryLabels[project.data.category] || project.data.category}</strong>
					</div>
					<div class="detail-row">
						<span>Launch Type</span>
						<strong>Reviewed listing</strong>
					</div>
					<div class="detail-row">
						<span>Focus</span>
						<strong>{project.data.description}</strong>
					</div>
					<div class="detail-row">
						<span>Links</span>
						<strong class="links-line">
							{project.data.url && <a href={project.data.url} target="_blank" rel="noreferrer">Open product</a>}
							{project.data.repo && <><span class="sep">•</span><a href={project.data.repo} target="_blank" rel="noreferrer">Open repository</a></>}
							<span class="sep">•</span><a href="/vendor/products/new">Submit your product</a>
						</strong>
					</div>
				</aside>
			</section>

			<section class="discussion-band" data-project-slug={project.id}>
				<div class="discussion-head">
					<div>
						<p class="section-kicker">Community notes</p>
						<h2>Discussion</h2>
					</div>
					<span id="comment-count">Loading comments</span>
				</div>

				<form id="comment-form" class="comment-composer">
					<div class="composer-body">
						<label for="comment-body">Add a useful product note</label>
						<div class="comment-toolbar" aria-label="Comment formatting tools">
							<button type="button" data-format="bold" title="Bold">B</button>
							<button type="button" data-format="italic" title="Italic"><em>I</em></button>
							<span class="toolbar-divider"></span>
							<button type="button" data-format="ordered" title="Numbered list">1.</button>
							<button type="button" data-format="unordered" title="Bullet list">-</button>
							<span class="toolbar-divider"></span>
							<button type="button" data-format="link" title="Link">Link</button>
							<button type="button" data-format="code" title="Code">Code</button>
							<button type="button" data-format="quote" title="Quote">"</button>
							<span class="toolbar-divider"></span>
							<button type="button" data-format="mention" title="Mention">@</button>
							<button type="button" data-format="image" title="Image">Image</button>
						</div>
						<input id="comment-image-input" type="file" accept="image/*" hidden />
						<div
							id="comment-body"
							class="comment-editor"
							contenteditable="true"
							role="textbox"
							aria-multiline="true"
							data-placeholder="Ask a sharp question, share field context, or point out what would make this product stronger."
						></div>
						<div class="composer-actions">
							<p id="comment-status" class="discussion-status" aria-live="polite">Sign in to post. Everyone can read the thread.</p>
							<button type="submit" class="composer-submit">Post comment</button>
						</div>
					</div>
				</form>

				<div id="comment-thread" class="comment-thread" aria-live="polite">
					<div class="comment-empty">Loading discussion...</div>
				</div>

				<div id="comment-link-modal" class="comment-modal" hidden>
					<div class="comment-modal-panel" role="dialog" aria-modal="true" aria-labelledby="comment-link-title">
						<form id="comment-link-form">
							<h3 id="comment-link-title">Add link</h3>
							<label for="comment-link-url">URL</label>
							<input id="comment-link-url" type="url" placeholder="https://example.com" autocomplete="off" />
							<div class="comment-modal-actions">
								<button type="button" id="comment-link-cancel">Cancel</button>
								<button type="submit">Add link</button>
							</div>
						</form>
					</div>
				</div>
			</section>

			<section class="footer-band">
				<a href="/" class="back-link">← Back to Best Products</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.product-page {
		width: min(1280px, calc(100% - 3rem));
		max-width: none;
		padding: 2rem 0 4rem;
	}
	.hero-band {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 320px;
		gap: 1.5rem;
		padding: 0.25rem 0.75rem 1.5rem;
		padding-bottom: 1.5rem;
		margin-bottom: 1.5rem;
		border-bottom: 1px solid var(--ui-border);
	}
	.product-topline {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		align-items: center;
		margin-bottom: 0.85rem;
	}
	.category-badge,
	.status-chip {
		display: inline-flex;
		align-items: center;
		min-height: 36px;
		padding: 0 1rem;
		border-radius: 6px;
		font-size: 0.78rem;
		font-weight: 950;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}
	.category-badge {
		border: 1px solid var(--accent);
		background: var(--accent);
		color: white;
	}
	.status-chip {
		border: 1px solid var(--accent);
		background: var(--accent);
		color: white;
	}
	.hero-main h1 {
		margin: 0;
		color: #0f172a;
		max-width: none;
		font-size: clamp(1.7rem, 2.6vw, 2.65rem);
		font-weight: 900;
		letter-spacing: 0;
		line-height: 1.06;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.tagline {
		max-width: 860px;
		margin: 1rem 0 0;
		color: #334155;
		font-size: clamp(1.05rem, 1.8vw, 1.35rem);
		line-height: 1.6;
	}
	.support-line {
		max-width: 760px;
		margin: 1rem 0 0;
		color: #64748b;
		font-size: 0.95rem;
		font-weight: 650;
	}
	.hero-actions {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
		margin-top: 1.5rem;
	}
	.btn-primary,
	.btn-secondary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 40px;
		padding: 0 1rem;
		border-radius: 6px;
		font-size: 0.78rem;
		font-weight: 950;
		letter-spacing: 0.1em;
		text-decoration: none;
		text-transform: uppercase;
	}
	.btn-primary {
		background: var(--accent);
		color: white;
	}
	.btn-primary:hover {
		background: var(--accent-dark);
		color: white;
	}
	.btn-secondary {
		border: 1px solid var(--accent);
		background: var(--accent);
		color: white;
	}
	.btn-secondary:hover {
		background: var(--accent-dark);
		border-color: var(--accent-dark);
		color: white;
	}
	.meta-strip {
		display: grid;
		gap: 0;
		border: 1px solid var(--ui-border);
		border-radius: 4px;
		overflow: hidden;
	}
	.meta-row {
		padding: 0.9rem 0.95rem;
		border-bottom: 1px solid var(--ui-border);
	}
	.meta-row:last-child {
		border-bottom: 0;
	}
	.meta-row span {
		display: block;
		margin-bottom: 0.35rem;
		color: #94a3b8;
		font-size: 0.68rem;
		font-weight: 950;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}
	.meta-row strong {
		color: #0f172a;
		font-size: 0.95rem;
		line-height: 1.45;
	}
	.visual-band {
		margin-top: 1.5rem;
	}
	.visual-frame {
		overflow: hidden;
		border: 1px solid var(--ui-border);
		border-radius: 4px;
		background: #0f172a;
	}
	.visual-frame img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 0;
	}
	.visual-placeholder {
		display: grid;
		grid-template-columns: 76px minmax(0, 1fr);
		gap: 1rem;
		align-items: center;
		padding: 2rem;
		min-height: 260px;
		background:
			radial-gradient(circle at top left, rgba(16, 185, 129, 0.18), transparent 28%),
			linear-gradient(135deg, #0f172a 0%, #111827 100%);
		color: white;
	}
	.mark {
		display: grid;
		place-items: center;
		width: 76px;
		height: 76px;
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.08);
		font-size: 2rem;
		font-weight: 900;
	}
	.visual-placeholder p {
		margin: 0;
		font-size: 1.2rem;
		font-weight: 850;
	}
	.visual-placeholder span {
		display: block;
		margin-top: 0.35rem;
		color: #cbd5e1;
	}
	.detail-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 340px;
		gap: 1.5rem;
		padding-inline: 0.75rem;
		margin-top: 1.5rem;
	}
	.discussion-band {
		padding: 1.75rem 0.75rem 0;
	}
	.discussion-head {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1.1rem;
		padding-bottom: 0.95rem;
		border-bottom: 1px solid var(--ui-border);
	}
	.section-kicker {
		margin: 0 0 0.2rem;
		color: #94a3b8;
		font-size: 0.68rem;
		font-weight: 950;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}
	.discussion-head h2 {
		margin: 0;
		color: #0f172a;
		font-size: 1.35rem;
		font-weight: 900;
		letter-spacing: 0;
	}
	.discussion-head span {
		color: #64748b;
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	.comment-composer {
		padding: 1rem 1.1rem;
		border: 1px solid var(--ui-border);
		border-radius: 6px;
		background: white;
		box-shadow: 0 10px 24px rgba(15, 23, 42, 0.04);
	}
	.comment-avatar {
		display: grid;
		place-items: center;
		width: 42px;
		height: 42px;
		border: 1px solid var(--ui-border);
		border-radius: 4px;
		background: #f8fafc;
		color: #0f172a;
		font-size: 0.76rem;
		font-weight: 900;
	}
	.comment-avatar {
		overflow: hidden;
	}
	.comment-avatar img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.composer-body label {
		display: block;
		margin-bottom: 0.55rem;
		color: #0f172a;
		font-size: 0.85rem;
		font-weight: 900;
	}
	.comment-toolbar {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.25rem;
		max-height: 0;
		margin-bottom: 0;
		padding: 0.35rem;
		border: 1px solid var(--ui-border);
		border-radius: 4px;
		background: #f8fafc;
		opacity: 0;
		overflow: hidden;
		pointer-events: none;
		transform: translateY(-4px);
		transition:
			max-height 0.16s ease,
			margin-bottom 0.16s ease,
			opacity 0.16s ease,
			transform 0.16s ease;
	}
	.comment-composer:focus-within .comment-toolbar {
		max-height: 96px;
		margin-bottom: 0.65rem;
		opacity: 1;
		pointer-events: auto;
		transform: translateY(0);
	}
	.comment-toolbar button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 34px;
		height: 32px;
		padding: 0 0.55rem;
		border: 0;
		border-radius: 4px;
		background: transparent;
		color: #475569;
		font: inherit;
		font-size: 0.78rem;
		font-weight: 900;
	}
	.comment-toolbar button:hover,
	.comment-toolbar button:focus-visible {
		background: white;
		color: #0f172a;
		outline: 1px solid var(--ui-border);
	}
	.toolbar-divider {
		width: 1px;
		height: 24px;
		margin: 0 0.2rem;
		background: var(--ui-border);
	}
	.comment-editor {
		display: block;
		width: 100%;
		min-height: 112px;
		box-sizing: border-box;
		padding: 0.95rem 1rem;
		border: 1px solid var(--ui-border);
		border-radius: 4px;
		background: #f8fafc;
		color: #0f172a;
		font: inherit;
		font-size: 0.95rem;
		line-height: 1.6;
		overflow-wrap: anywhere;
	}
	.comment-editor:focus {
		border-color: var(--accent);
		background: white;
		outline: 3px solid rgba(16, 185, 129, 0.14);
	}
	.comment-editor:empty::before {
		content: attr(data-placeholder);
		color: #94a3b8;
		pointer-events: none;
	}
	.comment-editor p {
		margin: 0.45rem 0 0;
	}
	.comment-editor p:first-child {
		margin-top: 0;
	}
	.comment-editor ul,
	.comment-editor ol {
		margin: 0.5rem 0 0;
		padding-left: 1.25rem;
	}
	.comment-editor blockquote {
		margin: 0.6rem 0 0;
		padding: 0.5rem 0.75rem;
		border-left: 3px solid var(--accent);
		background: #eefdf6;
		color: #475569;
	}
	.comment-editor code {
		padding: 0.12rem 0.32rem;
		border: 1px solid var(--ui-border);
		border-radius: 4px;
		background: white;
		color: #0f172a;
		font-size: 0.86em;
	}
	.comment-editor img {
		display: block;
		max-width: min(100%, 520px);
		max-height: 320px;
		margin-top: 0.65rem;
		border: 1px solid var(--ui-border);
		border-radius: 6px;
		object-fit: contain;
		background: white;
	}
	.composer-actions {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 0.75rem;
	}
	.discussion-status {
		margin: 0;
		color: #64748b;
		font-size: 0.82rem;
		line-height: 1.5;
	}
	.composer-submit {
		min-height: 38px;
		padding: 0 1.05rem;
		border: 1px solid var(--accent);
		border-radius: 4px;
		background: var(--accent);
		color: white;
		font: inherit;
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	.composer-submit:hover {
		background: var(--accent-dark);
		border-color: var(--accent-dark);
	}
	.composer-submit:disabled {
		cursor: not-allowed;
		opacity: 0.55;
	}
	:global(.comment-thread) {
		display: grid;
		gap: 0.75rem;
		margin-top: 0.95rem;
	}
	:global(.comment) {
		padding: 1rem 1.1rem;
		border: 1px solid var(--ui-border);
		border-radius: 10px;
		background: white;
		box-shadow: 0 8px 20px rgba(15, 23, 42, 0.035);
	}
	:global(.comment.is-reply) {
		margin-top: 0.7rem;
		margin-left: 1.4rem;
		padding-left: 1rem;
		border-left: 3px solid var(--accent);
		background: linear-gradient(180deg, #fcfffe 0%, #f8fbff 100%);
	}
	:global(.comment-head) {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
	}
	:global(.comment-author) {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		min-width: 0;
	}
	:global(.comment-head strong) {
		display: block;
		color: #0f172a;
		font-size: 0.98rem;
		font-weight: 900;
	}
	:global(.comment-head span) {
		display: block;
		margin-top: 0.15rem;
		color: #94a3b8;
		font-size: 0.76rem;
		font-weight: 750;
	}
	:global(.comment-time) {
		flex: 0 0 auto;
		color: #94a3b8;
		font-size: 0.74rem;
		font-weight: 850;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}
	:global(.comment p) {
		margin: 0.85rem 0 0;
		color: #334155;
		line-height: 1.7;
	}
	:global(.comment-body) {
		margin-top: 0.9rem;
		color: #334155;
		line-height: 1.7;
	}
	:global(.comment-body p) {
		margin: 0.65rem 0 0;
	}
	:global(.comment-body p:first-child) {
		margin-top: 0;
	}
	:global(.comment-body a) {
		color: var(--accent);
		font-weight: 800;
		text-decoration: none;
	}
	:global(.comment-body a:hover) {
		color: var(--accent-dark);
		text-decoration: underline;
	}
	:global(.comment-body code) {
		padding: 0.15rem 0.35rem;
		border: 1px solid var(--ui-border);
		border-radius: 4px;
		background: #f8fafc;
		color: #0f172a;
		font-size: 0.86em;
	}
	:global(.comment-body blockquote) {
		margin: 0.75rem 0 0;
		padding: 0.55rem 0.75rem;
		border-left: 3px solid var(--accent);
		background: #f8fafc;
		color: #475569;
	}
	:global(.comment-body ul),
	:global(.comment-body ol) {
		margin: 0.65rem 0 0;
		padding-left: 1.25rem;
	}
	:global(.comment-body img) {
		display: block;
		max-width: min(100%, 620px);
		max-height: 420px;
		margin-top: 0.75rem;
		border: 1px solid var(--ui-border);
		border-radius: 6px;
		object-fit: contain;
		background: #f8fafc;
	}
	:global(.comment-mention) {
		color: #0f172a;
		font-weight: 900;
	}
	:global(.comment-actions) {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-top: 0.9rem;
	}
	:global(.reply-composer) {
		margin-top: 0.9rem;
		padding: 0.9rem;
		border: 1px solid #cbd5e1;
		border-radius: 8px;
		background: #f8fafc;
	}
	:global(.reply-composer-label) {
		margin: 0 0 0.45rem;
		color: #334155;
		font-size: 0.78rem;
		font-weight: 800;
	}
	:global(.reply-composer textarea) {
		width: 100%;
		min-height: 92px;
		box-sizing: border-box;
		padding: 0.8rem 0.9rem;
		border: 1px solid var(--ui-border);
		border-radius: 6px;
		background: white;
		color: #0f172a;
		font: inherit;
		line-height: 1.6;
		resize: vertical;
	}
	:global(.reply-composer textarea:focus) {
		outline: 3px solid rgba(16, 185, 129, 0.14);
		border-color: var(--accent);
	}
	:global(.reply-composer-actions) {
		display: flex;
		justify-content: flex-end;
		gap: 0.65rem;
