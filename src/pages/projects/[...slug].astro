</style>

<script>
	import { ConvexHttpClient } from 'convex/browser';

	type ProductComment = {
		_id: string;
		body: string;
		createdAt: number;
		parentCommentId?: string;
		upvoteCount?: number;
		voted?: boolean;
		authorName?: string;
		authorImage?: string;
		replyToAuthorName?: string;
	};

	const discussion = document.querySelector<HTMLElement>('.discussion-band');
	const commentForm = document.getElementById('comment-form') as HTMLFormElement | null;
	const commentBody = document.getElementById('comment-body') as HTMLElement | null;
	const commentImageInput = document.getElementById('comment-image-input') as HTMLInputElement | null;
	const commentLinkModal = document.getElementById('comment-link-modal') as HTMLElement | null;
	const commentLinkForm = document.getElementById('comment-link-form') as HTMLFormElement | null;
	const commentLinkUrl = document.getElementById('comment-link-url') as HTMLInputElement | null;
	const commentLinkCancel = document.getElementById('comment-link-cancel') as HTMLButtonElement | null;
	const commentThread = document.getElementById('comment-thread');
	const commentCount = document.getElementById('comment-count');
	const commentStatus = document.getElementById('comment-status');
	const projectSlug = discussion?.dataset.projectSlug;
	const convexUrl = import.meta.env.PUBLIC_GABA_CONVEX_URL;
	let savedLinkRange: Range | null = null;
	let replyingTo: ProductComment | null = null;
	let currentComments: ProductComment[] = [];

	function escapeHtml(value: unknown) {
		return String(value ?? '')
			.replaceAll('&', '&amp;')
			.replaceAll('<', '&lt;')
			.replaceAll('>', '&gt;')
			.replaceAll('"', '&quot;')
			.replaceAll("'", '&#039;');
	}

	function isSafeUrl(value: string, allowDataImage = false) {
		if (allowDataImage && /^data:image\/(png|jpe?g|gif|webp);base64,/i.test(value)) {
			return true;
		}
		try {
			const url = new URL(value);
			return url.protocol === 'https:' || url.protocol === 'http:';
		} catch {
			return false;
		}
	}

	function sanitizeCommentHtml(value: string) {
		const template = document.createElement('template');
		template.innerHTML = value;
		const allowedTags = new Set(['A', 'B', 'BLOCKQUOTE', 'BR', 'CODE', 'DIV', 'EM', 'I', 'IMG', 'LI', 'OL', 'P', 'SPAN', 'STRONG', 'UL']);
		const unwrap = (node: Element) => {
			const parent = node.parentNode;
			if (!parent) return;
			while (node.firstChild) parent.insertBefore(node.firstChild, node);
			parent.removeChild(node);
		};

		template.content.querySelectorAll('*').forEach((element) => {
			if (!allowedTags.has(element.tagName)) {
				unwrap(element);
				return;
			}

			const href = element.tagName === 'A' ? element.getAttribute('href') || '' : '';
			const src = element.tagName === 'IMG' ? element.getAttribute('src') || '' : '';
			const alt = element.tagName === 'IMG' ? element.getAttribute('alt') || '' : '';
			Array.from(element.attributes).forEach((attribute) => element.removeAttribute(attribute.name));

			if (element.tagName === 'A') {
				if (isSafeUrl(href)) {
					element.setAttribute('href', href);
					element.setAttribute('target', '_blank');
					element.setAttribute('rel', 'noreferrer');
				} else {
					unwrap(element);
				}
			}

			if (element.tagName === 'IMG') {
				if (isSafeUrl(src, true)) {
					element.setAttribute('src', src);
					element.setAttribute('alt', alt || 'Comment image');
					element.setAttribute('loading', 'lazy');
				} else {
					element.remove();
				}
			}

			if (element.tagName === 'SPAN' && /^@\S+/.test(element.textContent || '')) {
				element.setAttribute('class', 'comment-mention');
			}
		});

		return template.innerHTML.trim();
	}

	function plainTextFromHtml(value: string) {
		const template = document.createElement('template');
		template.innerHTML = value;
		return (template.content.textContent || '').trim();
	}

	function insertHtmlAtCursor(html: string) {
		if (!commentBody) return;
		commentBody.focus();
		document.execCommand('insertHTML', false, html);
	}

	function saveEditorSelection() {
		const selection = window.getSelection();
		if (!selection || selection.rangeCount === 0 || !commentBody) return;
		const range = selection.getRangeAt(0);
		if (commentBody.contains(range.commonAncestorContainer)) {
			savedLinkRange = range.cloneRange();
		}
	}

	function restoreEditorSelection() {
		if (!savedLinkRange) return;
		const selection = window.getSelection();
		selection?.removeAllRanges();
		selection?.addRange(savedLinkRange);
	}

	function openLinkModal() {
		saveEditorSelection();
		if (!commentLinkModal || !commentLinkUrl) return;
		commentLinkUrl.value = '';
		commentLinkModal.hidden = false;
		window.setTimeout(() => commentLinkUrl.focus(), 0);
	}

	function closeLinkModal() {
		if (!commentLinkModal) return;
		commentLinkModal.hidden = true;
		commentBody?.focus();
	}

	function applyLink(href: string) {
		restoreEditorSelection();
		const selection = window.getSelection()?.toString();
		if (selection) {
			document.execCommand('createLink', false, href);
			const anchor = commentBody?.querySelector(`a[href="${CSS.escape(href)}"]`);
			anchor?.setAttribute('target', '_blank');
			anchor?.setAttribute('rel', 'noreferrer');
		} else {
			insertHtmlAtCursor(`<a href="${escapeHtml(href)}" target="_blank" rel="noreferrer">${escapeHtml(href)}</a>`);
		}
		savedLinkRange = null;
	}

	function renderInlineMarkdown(value: string) {
		let rendered = escapeHtml(value);
		rendered = rendered.replace(/`([^`]+)`/g, '<code>$1</code>');
		rendered = rendered.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
		rendered = rendered.replace(/\*([^*]+)\*/g, '<em>$1</em>');
		rendered = rendered.replace(/\[([^\]]+)\]\((https?:\/\/[^)\s]+)\)/g, (_match, label, url) => {
			return isSafeUrl(url)
				? `<a href="${escapeHtml(url)}" target="_blank" rel="noreferrer">${label}</a>`
				: label;
		});
		rendered = rendered.replace(/(^|\s)@([a-zA-Z0-9_.-]{2,32})/g, '$1<span class="comment-mention">@$2</span>');
		return rendered;
	}

	function renderCommentBody(value: string) {
		const lines = value.split(/\r?\n/);
		const html: string[] = [];
		let listType: 'ul' | 'ol' | null = null;

		const closeList = () => {
			if (listType) {
				html.push(`</${listType}>`);
				listType = null;
			}
		};

		for (const line of lines) {
			const trimmed = line.trim();
			if (!trimmed) {
				closeList();
				continue;
			}

			const imageMatch = trimmed.match(/^!\[([^\]]*)\]\((https?:\/\/[^)\s]+)\)$/);
			if (imageMatch && isSafeUrl(imageMatch[2], true)) {
				closeList();
				html.push(`<img src="${escapeHtml(imageMatch[2])}" alt="${escapeHtml(imageMatch[1] || 'Comment image')}" loading="lazy" />`);
				continue;
			}

			const unorderedMatch = trimmed.match(/^[-*]\s+(.+)$/);
			if (unorderedMatch) {
				if (listType !== 'ul') {
					closeList();
					html.push('<ul>');
					listType = 'ul';
				}
				html.push(`<li>${renderInlineMarkdown(unorderedMatch[1])}</li>`);
				continue;
			}

			const orderedMatch = trimmed.match(/^\d+\.\s+(.+)$/);
			if (orderedMatch) {
				if (listType !== 'ol') {
					closeList();
					html.push('<ol>');
					listType = 'ol';
				}
				html.push(`<li>${renderInlineMarkdown(orderedMatch[1])}</li>`);
				continue;
			}

			const quoteMatch = trimmed.match(/^>\s?(.+)$/);
			if (quoteMatch) {
				closeList();
				html.push(`<blockquote>${renderInlineMarkdown(quoteMatch[1])}</blockquote>`);
				continue;
			}

			closeList();
			html.push(`<p>${renderInlineMarkdown(trimmed)}</p>`);
		}

		closeList();
		return html.join('');
	}

	function renderStoredCommentBody(value: string) {
		if (/<[a-z][\s\S]*>/i.test(value)) {
			return sanitizeCommentHtml(value);
		}
		return renderCommentBody(value);
	}

	function insertFormatting(format: string) {
		if (!commentBody) return;
		commentBody.focus();

		if (format === 'bold') document.execCommand('bold');
		if (format === 'italic') document.execCommand('italic');
		if (format === 'ordered') document.execCommand('insertOrderedList');
		if (format === 'unordered') document.execCommand('insertUnorderedList');
		if (format === 'quote') document.execCommand('formatBlock', false, 'blockquote');
		if (format === 'code') insertHtmlAtCursor('<code>code</code>');
		if (format === 'mention') insertHtmlAtCursor('<span class="comment-mention">@maker</span>&nbsp;');
		if (format === 'link') {
			openLinkModal();
		}
		if (format === 'image') {
			commentImageInput?.click();
		}
	}

	function initials(name: string) {
		const letters = name
			.split(/\s+/)
			.filter(Boolean)
			.slice(0, 2)
			.map((part) => part[0]?.toUpperCase())
			.join('');
		return letters || 'G';
	}

	function formatCommentTime(createdAt: number) {
		const diff = createdAt - Date.now();
		const minute = 60 * 1000;
		const hour = 60 * minute;
		const day = 24 * hour;
		const formatter = new Intl.RelativeTimeFormat('en', { numeric: 'auto' });

		if (Math.abs(diff) < hour) return formatter.format(Math.round(diff / minute), 'minute');
		if (Math.abs(diff) < day) return formatter.format(Math.round(diff / hour), 'hour');
		return formatter.format(Math.round(diff / day), 'day');
	}

	function updateCount(count: number) {
		if (!commentCount) return;
		commentCount.textContent = `${count} ${count === 1 ? 'comment' : 'comments'}`;
	}

	function renderComments(comments: ProductComment[]) {
		currentComments = comments;
		updateCount(comments.length);
		if (!commentThread) return;

		if (comments.length === 0) {
			commentThread.innerHTML = '<div class="comment-empty">No comments yet. Start with a useful question, local context, or a concrete product suggestion.</div>';
			return;
		}

		const byParent = new Map<string, ProductComment[]>();
		for (const comment of comments) {
			const key = comment.parentCommentId || 'root';
			const bucket = byParent.get(key) || [];
			bucket.push(comment);
			byParent.set(key, bucket);
		}

		const renderBranch = (parentId = 'root') => (byParent.get(parentId) || [])
			.map((comment) => {
				const authorName = comment.authorName || 'GABA member';
				const avatar = comment.authorImage
					? `<img src="${escapeHtml(comment.authorImage)}" alt="" />`
					: escapeHtml(initials(authorName));
				const replyBadge = comment.replyToAuthorName ? `Reply to ${escapeHtml(comment.replyToAuthorName)}` : 'Product feedback';
				const replyBox = replyingTo?._id === comment._id
					? `
						<form class="reply-composer" data-reply-form="${escapeHtml(comment._id)}">
							<p class="reply-composer-label">Replying to <strong>${escapeHtml(authorName)}</strong></p>
							<textarea name="replyBody" placeholder="Write your reply here..."></textarea>
							<div class="reply-composer-actions">
								<button type="button" class="reply-cancel" data-action="cancel-reply">Cancel</button>
								<button type="submit" class="composer-submit">Post reply</button>
							</div>
						</form>
					`
					: '';
				return `
					<article class="comment${comment.parentCommentId ? ' is-reply' : ''}" data-comment-id="${escapeHtml(comment._id)}">
						<div class="comment-head">
							<div class="comment-author">
								<div class="comment-avatar">${avatar}</div>
								<div>
									<strong>${escapeHtml(authorName)}</strong>
									<span>${replyBadge}</span>
								</div>
							</div>
							<time class="comment-time" datetime="${new Date(comment.createdAt).toISOString()}">${escapeHtml(formatCommentTime(comment.createdAt))}</time>
						</div>
						<div class="comment-body">${renderStoredCommentBody(comment.body)}</div>
						<div class="comment-actions">
							<button type="button" class="comment-action${comment.voted ? ' is-voted' : ''}" data-action="upvote-comment" data-comment-id="${escapeHtml(comment._id)}">▲ ${escapeHtml(comment.upvoteCount || 0)}</button>
							<button type="button" class="comment-action" data-action="reply-comment" data-comment-id="${escapeHtml(comment._id)}">Reply</button>
						</div>
						${replyBox}
						${renderBranch(comment._id)}
					</article>
				`;
			})
			.join('');

		commentThread.innerHTML = renderBranch();
	}

	async function loadComments() {
		if (!projectSlug || !commentThread) return;
		if (!convexUrl) {
			renderComments([]);
			if (commentStatus) commentStatus.textContent = 'Comments need Convex config before posting is available.';
			return;
		}

		try {
			const client = new ConvexHttpClient(convexUrl);
			const comments = await client.query('products:listComments' as never, { targetSlug: projectSlug } as never);
			renderComments(Array.isArray(comments) ? comments as ProductComment[] : []);
		} catch {
			commentThread.innerHTML = '<div class="comment-empty">Comments not available.</div>';
			if (commentCount) commentCount.textContent = 'Comments unavailable';
		}
	}

	document.querySelectorAll<HTMLButtonElement>('.comment-toolbar button').forEach((button) => {
		button.addEventListener('click', () => insertFormatting(button.dataset.format || ''));
	});

	commentLinkForm?.addEventListener('submit', (event) => {
		event.preventDefault();
		const href = commentLinkUrl?.value.trim() || '';
		if (!isSafeUrl(href)) {
			if (commentStatus) commentStatus.textContent = 'Use a valid http or https link.';
			return;
		}
		applyLink(href);
		closeLinkModal();
	});

	commentLinkCancel?.addEventListener('click', () => {
		savedLinkRange = null;
		closeLinkModal();
	});

	commentLinkModal?.addEventListener('click', (event) => {
		if (event.target === commentLinkModal) {
			savedLinkRange = null;
			closeLinkModal();
		}
	});

	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape' && commentLinkModal && !commentLinkModal.hidden) {
			savedLinkRange = null;
			closeLinkModal();
		}
	});

	commentImageInput?.addEventListener('change', () => {
		const file = commentImageInput.files?.[0];
		commentImageInput.value = '';
		if (!file) return;
		if (!file.type.startsWith('image/')) {
			if (commentStatus) commentStatus.textContent = 'Choose an image file.';
			return;
		}
		if (file.size > 650_000) {
			if (commentStatus) commentStatus.textContent = 'Image is too large. Use an image under 650 KB.';
			return;
		}

		const reader = new FileReader();
		reader.onload = () => {
			const src = String(reader.result || '');
			if (isSafeUrl(src, true)) {
				insertHtmlAtCursor(`<img src="${escapeHtml(src)}" alt="${escapeHtml(file.name)}" loading="lazy" />`);
			}
		};
		reader.readAsDataURL(file);
	});

	commentThread?.addEventListener('click', async (event) => {
		const target = (event.target as HTMLElement).closest<HTMLButtonElement>('[data-action]');
		if (!target) return;
		const action = target.dataset.action;
		const commentId = target.dataset.commentId;


		if (action === 'cancel-reply') {
			replyingTo = null;
			renderComments(currentComments);
			return;
		}

		if (action === 'reply-comment' && commentId) {
			const article = target.closest<HTMLElement>('[data-comment-id]');
			const authorName = article?.querySelector('strong')?.textContent || 'GABA member';
			replyingTo = { _id: commentId, body: '', createdAt: Date.now(), authorName };
			renderComments(currentComments);
			window.setTimeout(() => {
				const textarea = commentThread?.querySelector<HTMLTextAreaElement>(`form[data-reply-form="${CSS.escape(commentId)}"] textarea`);
				textarea?.focus();
			}, 0);
			return;
		}

		if (action === 'upvote-comment' && commentId) {
			try {
				const { convexMutation } = await import('../../lib/convexAuthClient');
				await convexMutation('products:upvoteComment', { commentId });
				await loadComments();
			} catch (error: any) {
				if (commentStatus) commentStatus.textContent = error?.message || 'Sign in to upvote comments.';
			}
		}
	});

	commentThread?.addEventListener('submit', async (event) => {
		const form = event.target as HTMLFormElement;
		if (!form.matches('.reply-composer')) return;
		event.preventDefault();
		const textarea = form.querySelector<HTMLTextAreaElement>('textarea[name="replyBody"]');
		const body = sanitizeCommentHtml((textarea?.value || '').replaceAll('\n', '<br>'));
		const textBody = plainTextFromHtml(body);
		const submitButton = form.querySelector<HTMLButtonElement>('.composer-submit');
		if (!projectSlug || !replyingTo || textBody.length < 2) {
			if (commentStatus) commentStatus.textContent = 'Write at least two characters before posting.';
			return;
		}
		try {
			if (submitButton) submitButton.disabled = true;
			if (commentStatus) commentStatus.textContent = 'Posting reply...';
			const { convexMutation } = await import('../../lib/convexAuthClient');
			await convexMutation('products:createComment', { targetSlug: projectSlug, body, parentCommentId: replyingTo._id });
			replyingTo = null;
			if (commentStatus) commentStatus.textContent = 'Reply posted.';
			await loadComments();
		} catch (error: any) {
			if (commentStatus) commentStatus.textContent = error?.message || 'Sign in to post a reply.';
		} finally {
			if (submitButton) submitButton.disabled = false;
		}
	});

	commentForm?.addEventListener('submit', async (event) => {
		event.preventDefault();
		const body = sanitizeCommentHtml(commentBody?.innerHTML || '');
		const textBody = plainTextFromHtml(body);
		const hasImage = /<img\b/i.test(body);
		const submitButton = commentForm.querySelector<HTMLButtonElement>('.composer-submit');

		if (!projectSlug || (!hasImage && textBody.length < 2)) {
			if (commentStatus) commentStatus.textContent = 'Write at least two characters before posting.';
			return;
		}

		try {
			if (submitButton) submitButton.disabled = true;
			if (commentStatus) commentStatus.textContent = 'Posting comment...';
			const { convexMutation } = await import('../../lib/convexAuthClient');
			await convexMutation('products:createComment', { targetSlug: projectSlug, body });
			if (commentBody) commentBody.innerHTML = '';
			if (commentStatus) commentStatus.textContent = 'Comment posted.';
			await loadComments();
		} catch (error: any) {
			if (commentStatus) commentStatus.textContent = error?.message || 'Sign in to post a comment.';
		} finally {
			if (submitButton) submitButton.disabled = false;
		}
	});

	loadComments();
</script>
