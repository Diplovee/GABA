---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: project,
	}));
}

const project = Astro.props;
const { Content } = await render(project);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={project.data.title} description={project.data.description} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="header">
					<span class="category-badge">{project.data.category}</span>
					<h1>{project.data.title}</h1>
					<p class="description">{project.data.description}</p>
					<div class="links">
						{project.data.url && <a href={project.data.url} target="_blank" class="btn-primary">View Live Demo</a>}
						{project.data.repo && <a href={project.data.repo} target="_blank" class="btn-secondary">Source Code</a>}
					</div>
				</div>
				<hr />
				<div class="content">
					<Content />
				</div>
			</article>
			<a href="/projects" class="back-link">← Back to Projects</a>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 720px;
		margin: 0 auto;
		padding: 1em;
	}
	.header {
		text-align: center;
		padding: 2em 0;
	}
	.category-badge {
		display: inline-block;
		padding: 0.25em 0.75em;
		background: var(--zim-red);
		color: #fff;
		border-radius: 4px;
		font-size: 0.8em;
		font-weight: bold;
		text-transform: uppercase;
		margin-bottom: 1em;
	}
	h1 {
		margin: 0 0 0.5em 0;
	}
	.description {
		color: rgb(var(--gray));
		font-size: 1.1em;
	}
	.links {
		display: flex;
		gap: 1em;
		justify-content: center;
		margin-top: 1.5em;
	}
	.btn-primary,
	.btn-secondary {
		padding: 0.75em 1.5em;
		border-radius: 8px;
		text-decoration: none;
		font-weight: 600;
		transition: all 0.2s;
	}
	.btn-primary {
		background: var(--zim-green);
		color: #fff;
	}
	.btn-primary:hover {
		background: #1a6b2a;
	}
	.btn-secondary {
		background: transparent;
		border: 2px solid var(--zim-green);
		color: var(--zim-green);
	}
	.btn-secondary:hover {
		background: var(--zim-green);
		color: #fff;
	}
	hr {
		margin: 2em 0;
	}
	.content {
		line-height: 1.8;
	}
	.back-link {
		display: inline-block;
		margin-top: 2em;
		color: rgb(var(--gray));
		text-decoration: none;
	}
	.back-link:hover {
		color: var(--zim-green);
	}
</style>