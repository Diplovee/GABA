---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Advertise | GABA" description="Reach African tech makers, buyers, and early adopters through GABA." />
	</head>
	<body>
		<Header />
		<main class="simple-page">
			<p class="eyebrow">Reach African tech on African terms</p>
			<h1>Advertise</h1>
			<p class="lead">GABA monetization starts with useful placement: featured listings, relevant hiring, and verified trust signals for products that serve African markets.</p>
			<div class="pricing-grid">
				<section>
					<span>01</span>
					<h2>Featured Listings</h2>
					<p>Promote a product inside Best Products without hiding the problem, maker, country, or community signal.</p>
				</section>
				<section>
					<span>02</span>
					<h2>Job Board</h2>
					<p>Put African tech roles in front of makers and operators already browsing product launches.</p>
				</section>
				<section>
					<span>03</span>
					<h2>GABA Verified</h2>
					<p>A reviewed badge for products with confirmed maker details, credible links, and clear market context.</p>
				</section>
			</div>
			<a class="cta" href="/vendor">Request Access</a>
		</main>
		<Footer />
	</body>
</html>

<style>
	.simple-page {
		width: min(1180px, calc(100% - 3rem));
		max-width: none;
		padding: 4rem 0;
	}
	.eyebrow {
		margin: 0 0 0.8rem;
		color: var(--accent);
		font-size: 0.72rem;
		font-weight: 950;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}
	h1 {
		margin: 0;
		color: #0f172a;
		font-size: clamp(2.8rem, 7vw, 5rem);
		font-weight: 900;
		letter-spacing: -0.04em;
	}
	.lead {
		max-width: 760px;
		margin: 1rem 0 2rem;
		color: #475569;
		font-size: 1.08rem;
		line-height: 1.8;
	}
	.pricing-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-bottom: 2rem;
	}
	.pricing-grid section {
		border: 1px solid var(--ui-border);
		border-radius: 8px;
		background: white;
		padding: 1.25rem;
	}
	.pricing-grid span {
		color: #94a3b8;
		font-family: var(--font-mono);
		font-size: 0.78rem;
		font-weight: 900;
	}
	.pricing-grid h2 {
		margin: 0.8rem 0 0.7rem;
		color: #0f172a;
		font-size: 0.9rem;
		font-weight: 950;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	.pricing-grid p {
		margin: 0;
		color: #64748b;
		font-size: 0.92rem;
		line-height: 1.7;
	}
	.cta {
		display: inline-flex;
		border-radius: 6px;
		background: var(--accent);
		color: white;
		font-size: 0.78rem;
		font-weight: 950;
		letter-spacing: 0.08em;
		padding: 0.85rem 1.1rem;
		text-decoration: none;
		text-transform: uppercase;
	}
	.cta:hover {
		background: var(--accent-dark);
		color: white;
	}
	@media (max-width: 760px) {
		.simple-page {
			width: min(100% - 1.5rem, 1180px);
		}
		.pricing-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
