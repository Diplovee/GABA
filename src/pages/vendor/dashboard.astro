---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Profile Dashboard | GABA" description="Manage your profile, launches, settings, and account actions" />
	</head>
	<body>
		<Header />
		<main class="dashboard">
			<nav class="tab-nav" aria-label="Dashboard sections">
				<button class="tab-button active" type="button" data-tab="profile">Profile</button>
				<button class="tab-button" type="button" data-tab="products">My products</button>
				<button class="tab-button" type="button" data-tab="settings">Settings</button>
				<button class="tab-button" type="button" data-tab="api">API dashboard</button>
			</nav>

			<section class="tab-panel active" data-panel="profile">
				<section class="profile-hero surface">
					<div class="profile-avatar" id="profile-avatar">G</div>
					<div class="profile-identity">
						<h2 id="profile-display-name">Loading...</h2>
						<p id="profile-headline" class="profile-headline">Maker on GABA</p>
						<div class="profile-meta" id="profile-meta"></div>
						<div class="profile-stats" id="profile-stats"></div>
					</div>
					<div class="profile-hero-actions">
						<button id="open-edit-profile" class="btn-outline" type="button">Edit my profile</button>
						<button id="logout-button" class="btn-ghost" type="button">Logout</button>
					</div>
				</section>

				<nav class="profile-subnav" aria-label="Profile sections">
					<a href="#about-section" class="subnav-pill">About</a>
					<a href="#badges-section" class="subnav-pill">Badges</a>
					<a href="#recent-section" class="subnav-pill">Recent launches</a>
				</nav>

				<section id="about-section" class="profile-grid">
					<div class="content-column">
						<section class="surface section-surface">
							<div class="section-head">
								<h3>About</h3>
							</div>
							<div id="profile-about" class="about-box"></div>
						</section>

						<section id="badges-section" class="surface section-surface">
							<div class="section-head">
								<h3>Badges</h3>
							</div>
							<div id="badge-list" class="badge-list"></div>
						</section>

						<section id="recent-section" class="surface section-surface">
							<div class="section-head">
								<h3>Recently launched</h3>
							</div>
							<div id="recent-launches" class="recent-list"></div>
						</section>
					</div>

					<aside class="side-column">
						<section class="surface section-surface">
							<div class="section-head">
								<div>
									<h3>Maker plan</h3>
									<p>Your current subscription snapshot.</p>
								</div>
							</div>
							<div id="subscription-status" class="subscription-box">
								<p class="loading">Loading...</p>
							</div>
							<a href="/pricing" class="btn-outline">Manage plan</a>
						</section>
					</aside>
				</section>
			</section>

			<section class="tab-panel" data-panel="products">
				<section class="surface section-surface">
					<div class="section-head">
						<div>
							<h3>My products & launches</h3>
							<p>Track launch status, drafts, and active listings from one place.</p>
						</div>
						<a href="/vendor/products/new" class="btn-primary">Submit product</a>
					</div>
					<div class="products-grid">
						<div class="products-card">
							<h4>Launches</h4>
							<div id="launch-filters" class="filter-list"></div>
						</div>
						<div class="products-card">
							<h4>Products</h4>
							<div id="product-summary-list" class="summary-list"></div>
						</div>
						<div class="products-card">
							<h4>Need help?</h4>
							<div class="help-links">
								<a href="/about">Launch guide</a>
								<a href="/pricing">Plans and support</a>
							</div>
						</div>
					</div>
				</section>
				<section class="surface section-surface products-list-surface">
					<div class="section-head compact-head">
						<div>
							<h3 id="products-panel-title">All launches</h3>
							<p id="products-panel-copy">Loading your launches...</p>
						</div>
					</div>
					<div id="products-list" class="products-list">
						<p class="loading">Loading products...</p>
					</div>
				</section>
			</section>

			<section class="tab-panel" data-panel="settings">
				<section class="settings-grid">
					<section class="surface section-surface">
						<div class="section-head">
							<div>
								<h3>Verification</h3>
								<p>Show that this maker account is real and actively managed.</p>
							</div>
						</div>
						<div id="verification-status" class="settings-copy"></div>
						<div class="settings-actions">
							<button id="verify-account-button" class="btn-primary" type="button">Verify account</button>
						</div>
					</section>

					<section class="surface section-surface">
						<div class="section-head">
							<div>
								<h3>Account state</h3>
								<p>Control whether the account remains active.</p>
							</div>
						</div>
						<div id="account-status-copy" class="settings-copy"></div>
						<div class="settings-actions">
							<button id="deactivate-account-button" class="btn-outline danger-outline" type="button">Deactivate account</button>
						</div>
					</section>

					<section class="surface section-surface">
						<div class="section-head">
							<div>
								<h3>Delete account</h3>
								<p>Keep this conservative until a full self-serve delete flow exists.</p>
							</div>
						</div>
						<div class="settings-copy">
							<p>A delete request marks the account for removal review and signs you out.</p>
						</div>
						<div class="settings-actions">
							<button id="delete-account-button" class="btn-danger" type="button">Request account deletion</button>
						</div>
					</section>
				</section>
			</section>

			<section class="tab-panel" data-panel="api">
				<section class="surface section-surface api-panel">
					<div class="section-head">
						<div>
							<h3>API dashboard</h3>
							<p>Reserved for API keys, webhooks, and product automation.</p>
						</div>
					</div>
					<div class="api-placeholder">
						<strong>Coming next</strong>
						<p>Generate publish tokens, connect product pipelines, and inspect launch activity from one place.</p>
					</div>
				</section>
			</section>
		</main>
		<div id="edit-profile-modal" class="modal-shell" hidden>
			<div class="modal-backdrop" data-close-modal></div>
			<section class="modal-panel surface" aria-labelledby="edit-profile-title" aria-modal="true" role="dialog">
				<div class="section-head modal-head">
					<div>
						<h3 id="edit-profile-title">Edit profile</h3>
						<p>Update your public maker details.</p>
					</div>
					<div class="modal-head-actions">
						<span id="profile-status" class="inline-note">Signed in</span>
						<button id="close-edit-profile" class="modal-close" type="button" aria-label="Close edit profile">×</button>
					</div>
				</div>

				<form id="profile-form" class="profile-form">
					<label>
						<span>Contact name</span>
						<input id="profile-name" name="name" type="text" placeholder="Your name" />
					</label>
					<label>
						<span>Maker or studio</span>
						<input id="profile-business" name="businessName" type="text" placeholder="Studio or business name" />
					</label>
					<label>
						<span>Headline</span>
						<input id="profile-headline-input" name="headline" type="text" placeholder="I'm a builder shipping useful tools" />
					</label>
					<label>
						<span>Phone</span>
						<input id="profile-phone" name="phone" type="tel" placeholder="+263 77 123 4567" />
					</label>
					<label class="full-span">
						<span>Bio</span>
						<textarea id="profile-bio" name="bio" rows="5" placeholder="Add a bio so people can understand your work, skills, and what you are building."></textarea>
					</label>
					<label class="full-span">
						<span>Email</span>
						<input id="profile-email" name="email" type="email" readonly />
					</label>
					<div class="form-actions full-span">
						<button id="save-profile-button" class="btn-primary" type="submit">Save profile</button>
						<span id="profile-message" class="form-message"></span>
					</div>
				</form>
			</section>
		</div>
		<Footer />
	</body>
</html>

<script>
	import { convexMutation, convexQuery, signOut } from '../../lib/convexAuthClient';

	type UserRecord = any;
	type ProductRecord = any;
	type SubscriptionRecord = any;

	let currentUser: UserRecord = null;
	let currentProducts: ProductRecord[] = [];
	let currentSubscription: SubscriptionRecord = null;
	let activeProductFilter = 'all';

	function getInitials(user: UserRecord) {
		const source = user?.name || user?.businessName || user?.email || 'G';
		return source
			.split(/\s+/)
			.map((part: string) => part[0] || '')
			.join('')
			.slice(0, 2)
			.toUpperCase();
	}

	function setActiveTab(tab: string, updateHistory = true) {
		const nextTab = ['profile', 'products', 'settings', 'api'].includes(tab) ? tab : 'profile';
		document.querySelectorAll('.tab-button').forEach((button) => {
			button.classList.toggle('active', (button as HTMLButtonElement).dataset.tab === nextTab);
		});
		document.querySelectorAll('.tab-panel').forEach((panel) => {
			panel.classList.toggle('active', panel.getAttribute('data-panel') === nextTab);
		});

		if (updateHistory) {
			const url = new URL(window.location.href);
			url.searchParams.set('tab', nextTab);
			window.history.replaceState({}, '', url.toString());
		}
	}

	function getProductCollections(products: ProductRecord[]) {
		const now = Date.now();
		const scheduled = products.filter((product) => typeof product.launchAt === 'number' && product.launchAt > now);
		const drafts = products.filter((product) => product.status === 'draft');
		const posted = products.filter((product) => product.status === 'active' && (!product.launchAt || product.launchAt <= now));
		const inProgress = products.filter((product) => product.reviewStatus === 'pending' || product.status === 'draft');
		return {
			all: products,
			in_progress: inProgress,
			drafts,
			scheduled,
			posted,
		};
	}

	function formatDate(dateValue?: number) {
		if (!dateValue) return 'No launch date set';
		return new Date(dateValue).toLocaleString('en-US', {
			month: 'long',
			day: 'numeric',
			year: 'numeric',
			hour: 'numeric',
			minute: '2-digit',
		});
	}

	function setProfileMessage(text: string, type: 'error' | 'success' | 'neutral' = 'neutral') {
		const messageEl = document.getElementById('profile-message');
		if (!messageEl) return;
		messageEl.textContent = text;
		messageEl.dataset.type = type;
	}

	function fillProfileForm(user: UserRecord) {
		const nameInput = document.getElementById('profile-name') as HTMLInputElement | null;
		const businessInput = document.getElementById('profile-business') as HTMLInputElement | null;
		const headlineInput = document.getElementById('profile-headline-input') as HTMLInputElement | null;
		const phoneInput = document.getElementById('profile-phone') as HTMLInputElement | null;
		const bioInput = document.getElementById('profile-bio') as HTMLTextAreaElement | null;
		const emailInput = document.getElementById('profile-email') as HTMLInputElement | null;

		if (nameInput) nameInput.value = user?.name || '';
		if (businessInput) businessInput.value = user?.businessName || '';
		if (headlineInput) headlineInput.value = user?.headline || '';
		if (phoneInput) phoneInput.value = user?.phone || '';
		if (bioInput) bioInput.value = user?.bio || '';
		if (emailInput) emailInput.value = user?.email || '';
	}

	function renderProfileTab(user: UserRecord, products: ProductRecord[], subscription: SubscriptionRecord | null) {
		const avatar = document.getElementById('profile-avatar');
		const displayName = document.getElementById('profile-display-name');
		const headline = document.getElementById('profile-headline');
		const meta = document.getElementById('profile-meta');
		const stats = document.getElementById('profile-stats');
		const about = document.getElementById('profile-about');
		const badges = document.getElementById('badge-list');
		const recent = document.getElementById('recent-launches');
		const profileStatus = document.getElementById('profile-status');

		if (avatar) avatar.textContent = getInitials(user);
		if (displayName) displayName.textContent = user?.businessName || user?.name || 'GABA maker';
		if (headline) headline.textContent = user?.headline || "I'm a builder shipping useful tools";
		if (profileStatus) profileStatus.textContent = user?.email || 'Signed in';

		const activeCount = products.filter((product) => product.status === 'active').length;
		const scheduledCount = products.filter((product) => typeof product.launchAt === 'number' && product.launchAt > Date.now()).length;
		if (meta) {
			meta.innerHTML = `
				<span>${user?.email || 'No email available'}</span>
				<span>${products.length} launches</span>
				<span>${activeCount} active</span>
			`;
		}

		if (stats) {
			stats.innerHTML = `
				<div class="profile-stat"><strong>${products.length}</strong><span>Products</span></div>
				<div class="profile-stat"><strong>${scheduledCount}</strong><span>Scheduled</span></div>
				<div class="profile-stat"><strong>${subscription?.tierInfo?.name || 'Free'}</strong><span>Plan</span></div>
			`;
		}

		if (about) {
			about.innerHTML = user?.bio
				? `<p>${user.bio}</p>`
				: '<p><button type="button" class="inline-action" data-open-edit-inline>Add a bio</button> to help people understand your work, skills, history, and current launches.</p>';
		}

		if (badges) {
			const badgeItems = [
				{ tone: 'gold', label: products.length > 0 ? 'Shipper' : 'Getting started', value: `${products.length} launch${products.length === 1 ? '' : 'es'}` },
				{ tone: 'green', label: activeCount > 0 ? 'Live maker' : 'Pre-launch', value: `${activeCount} active` },
				{ tone: 'blue', label: subscription?.tierInfo?.name || 'Free plan', value: subscription?.daysRemaining ? `${subscription.daysRemaining} days left` : 'Plan available' },
			];
			badges.innerHTML = badgeItems.map((badge) => `
				<div class="badge-card ${badge.tone}">
					<span>${badge.label}</span>
					<strong>${badge.value}</strong>
				</div>
			`).join('');
		}

		if (recent) {
			const orderedProducts = [...products].sort((a, b) => (b.updatedAt || 0) - (a.updatedAt || 0)).slice(0, 3);
			if (orderedProducts.length === 0) {
				recent.innerHTML = '<p class="empty-note">No launches yet. Your next submission will show up here.</p>';
			} else {
				recent.innerHTML = orderedProducts.map((product) => `
					<article class="recent-item">
						<div class="recent-mark">${(product.name || 'P').slice(0, 1).toUpperCase()}</div>
						<div>
							<h4>${product.name}</h4>
							<p>${product.tagline || product.problemSolved || 'No summary yet.'}</p>
						</div>
						<a href="${product.liveUrl || product.demoUrl || product.repoUrl || '/'}" class="mini-link" target="_blank" rel="noreferrer">View</a>
					</article>
				`).join('');
			}
		}
	}

	function renderSubscription(subscription: SubscriptionRecord | null) {
		const statusEl = document.getElementById('subscription-status');
		if (!statusEl) return;

		if (!subscription) {
			statusEl.innerHTML = '<p>No active maker plan yet.</p><p>Choose a plan when you want more submissions or featured visibility.</p>';
			return;
		}

		statusEl.innerHTML = `
			<div class="subscription-grid">
				<div><span>Status</span><strong>${subscription.status}</strong></div>
				<div><span>Plan</span><strong>${subscription.tierInfo.name}</strong></div>
				<div><span>Days left</span><strong>${subscription.daysRemaining}</strong></div>
			</div>
		`;
	}

	function renderProductsNavigation(products: ProductRecord[]) {
		const filterContainer = document.getElementById('launch-filters');
		const summaryContainer = document.getElementById('product-summary-list');
		if (!filterContainer || !summaryContainer) return;

		const collections = getProductCollections(products);
		const filterDefs = [
			{ key: 'all', label: 'All', count: collections.all.length },
			{ key: 'in_progress', label: 'In Progress', count: collections.in_progress.length },
			{ key: 'drafts', label: 'Drafts', count: collections.drafts.length },
			{ key: 'scheduled', label: 'Scheduled', count: collections.scheduled.length },
			{ key: 'posted', label: 'Posted', count: collections.posted.length },
		];

		filterContainer.innerHTML = filterDefs.map((filter) => `
			<button type="button" class="filter-button${filter.key === activeProductFilter ? ' active' : ''}" data-filter="${filter.key}">
				<span class="filter-label">${filter.label}</span>
				<span class="filter-count">${filter.count}</span>
			</button>
		`).join('');

		summaryContainer.innerHTML = products.length === 0
			? '<p class="empty-note">No products yet.</p>'
			: products.map((product) => `
				<div class="summary-item">
					<div class="summary-mark">${(product.name || 'P').slice(0, 1).toUpperCase()}</div>
					<div>
						<strong>${product.name}</strong>
						<span>${product.status}</span>
					</div>
				</div>
			`).join('');

		filterContainer.querySelectorAll('.filter-button').forEach((button) => {
			button.addEventListener('click', () => {
				activeProductFilter = (button as HTMLButtonElement).dataset.filter || 'all';
				renderProductsNavigation(currentProducts);
				renderProductsList(currentProducts);
			});
		});
	}

	function renderProductsList(products: ProductRecord[]) {
		const productsList = document.getElementById('products-list');
		const panelTitle = document.getElementById('products-panel-title');
		const panelCopy = document.getElementById('products-panel-copy');
		if (!productsList || !panelTitle || !panelCopy) return;

		const collections = getProductCollections(products);
		const filtered = collections[activeProductFilter as keyof typeof collections] || collections.all;
		const labels: Record<string, string> = {
			all: 'All launches',
			in_progress: 'In progress',
			drafts: 'Drafts',
			scheduled: 'Scheduled',
			posted: 'Posted',
		};
		panelTitle.textContent = labels[activeProductFilter] || 'All launches';
		panelCopy.textContent = filtered.length === 0 ? 'Nothing in this section yet.' : `${filtered.length} item${filtered.length === 1 ? '' : 's'} in this section.`;

		if (filtered.length === 0) {
			productsList.innerHTML = '<p class="empty-note">No launches in this section yet.</p>';
			return;
		}

		productsList.innerHTML = filtered.map((product) => {
			const statusLabel = product.status === 'active' ? 'Posted' : typeof product.launchAt === 'number' && product.launchAt > Date.now() ? 'Scheduled' : 'Draft';
			return `
				<article class="launch-card">
					<div class="launch-mark">${(product.name || 'P').slice(0, 1).toUpperCase()}</div>
					<div class="launch-copy">
						<div class="launch-title-row">
							<h4>${product.name}</h4>
							<span class="launch-chip">${statusLabel}</span>
						</div>
						<p>${product.tagline || product.problemSolved || product.description || 'No summary yet.'}</p>
						<span class="launch-time">${typeof product.launchAt === 'number' ? `Scheduled on ${formatDate(product.launchAt)}` : 'Launch date not scheduled yet'}</span>
						<span class="launch-edited">Last edited ${formatDate(product.updatedAt)}</span>
					</div>
					<div class="launch-actions">
						<a href="/vendor/dashboard?tab=profile" class="btn-outline">Profile dashboard</a>
						<a href="${product.liveUrl || product.demoUrl || product.repoUrl || '/vendor/products/new'}" class="btn-primary" target="_blank" rel="noreferrer">View</a>
					</div>
				</article>
			`;
		}).join('');
	}

	function renderSettings(user: UserRecord) {
		const verification = document.getElementById('verification-status');
		const accountStatus = document.getElementById('account-status-copy');
		if (verification) {
			verification.innerHTML = user?.verificationRequestedAt
				? `<p>Verification requested on ${formatDate(user.verificationRequestedAt)}.</p>`
				: '<p>No verification request yet. Use this when you want a reviewed maker account.</p>';
		}
		if (accountStatus) {
			accountStatus.innerHTML = `<p>Current state: <strong>${user?.accountStatus || 'active'}</strong>.</p>`;
		}
	}

	async function loadDashboard() {
		try {
			const [user, products, subscription] = await Promise.all([
				convexQuery('users:getCurrent'),
				convexQuery('products:getMyProducts'),
				convexQuery('subscriptions:getMySubscription'),
			]);

			if (!user) {
				window.location.href = '/vendor';
				return;
			}

			currentUser = user;
			currentProducts = products;
			currentSubscription = subscription;

			fillProfileForm(user);
			renderProfileTab(user, products, subscription);
			renderSubscription(subscription);
			renderProductsNavigation(products);
			renderProductsList(products);
			renderSettings(user);
			setProfileMessage('Profile details are ready.');

			const requestedTab = new URL(window.location.href).searchParams.get('tab') || 'profile';
			setActiveTab(requestedTab, false);
		} catch (error) {
			console.error('Failed to load dashboard:', error);
			window.setTimeout(() => {
				window.location.href = '/vendor';
			}, 1200);
		}
	}

	document.querySelectorAll('.tab-button').forEach((button) => {
		button.addEventListener('click', () => {
			setActiveTab((button as HTMLButtonElement).dataset.tab || 'profile');
		});
	});

	const editProfileModal = document.getElementById('edit-profile-modal');
	const openEditProfile = () => {
		editProfileModal?.removeAttribute('hidden');
		document.body.style.overflow = 'hidden';
	};
	const closeEditProfile = () => {
		editProfileModal?.setAttribute('hidden', '');
		document.body.style.overflow = '';
	};

	document.getElementById('open-edit-profile')?.addEventListener('click', openEditProfile);
	document.getElementById('close-edit-profile')?.addEventListener('click', closeEditProfile);
	document.querySelectorAll('[data-close-modal]').forEach((element) => {
		element.addEventListener('click', closeEditProfile);
	});
	document.addEventListener('click', (event) => {
		const target = event.target as HTMLElement | null;
		if (target?.matches('[data-open-edit-inline]')) {
			openEditProfile();
		}
	});
	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape' && !editProfileModal?.hasAttribute('hidden')) {
			closeEditProfile();
		}
	});

	document.getElementById('profile-form')?.addEventListener('submit', async (event) => {
		event.preventDefault();
		const form = event.currentTarget as HTMLFormElement;
		const button = document.getElementById('save-profile-button') as HTMLButtonElement | null;
		const formData = new FormData(form);

		try {
			if (button) button.disabled = true;
			setProfileMessage('Saving profile...');
			const updatedUser = await convexMutation('users:updateCurrentProfile', {
				name: String(formData.get('name') || '').trim(),
				businessName: String(formData.get('businessName') || '').trim(),
				headline: String(formData.get('headline') || '').trim(),
				phone: String(formData.get('phone') || '').trim(),
				bio: String(formData.get('bio') || '').trim(),
			});
			currentUser = updatedUser;
			fillProfileForm(updatedUser);
			renderProfileTab(updatedUser, currentProducts, currentSubscription);
			renderSettings(updatedUser);
			setProfileMessage('Profile updated.', 'success');
			closeEditProfile();
		} catch (error: any) {
			setProfileMessage(error?.message || 'Could not save profile.', 'error');
		} finally {
			if (button) button.disabled = false;
		}
	});

	document.getElementById('verify-account-button')?.addEventListener('click', async () => {
		const updatedUser = await convexMutation('users:requestVerification');
		currentUser = updatedUser;
		renderSettings(updatedUser);
		setProfileMessage('Verification request submitted.', 'success');
		setActiveTab('settings');
	});

	document.getElementById('deactivate-account-button')?.addEventListener('click', async () => {
		const confirmed = window.confirm('Deactivate this account and sign out?');
		if (!confirmed) return;
		await convexMutation('users:deactivateCurrentAccount');
		await signOut();
		window.location.href = '/vendor';
	});

	document.getElementById('delete-account-button')?.addEventListener('click', async () => {
		const confirmed = window.confirm('Request account deletion and sign out?');
		if (!confirmed) return;
		await convexMutation('users:requestAccountDeletion');
		await signOut();
		window.location.href = '/vendor';
	});

	document.getElementById('logout-button')?.addEventListener('click', async () => {
		await signOut();
		window.location.href = '/vendor';
	});

	loadDashboard();
</script>

