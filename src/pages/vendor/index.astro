---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Maker Portal | GABA" description="Submit and manage your African tech products on GABA" />
	</head>
	<body>
		<Header />
		<main class="auth-page">
			<div class="auth-container">
				<div class="auth-header">
					<h1>Maker Portal</h1>
					<p>Submit your apps, gadgets, tools, and startup products for discovery</p>
				</div>

				<div class="auth-tabs">
					<button class="tab-btn active" data-tab="login">Login</button>
					<button class="tab-btn" data-tab="register">Register</button>
				</div>

				<div id="login-form" class="auth-form">
					<form id="loginForm">
						<div class="form-group">
							<label for="email">Email</label>
							<input type="email" id="email" name="email" required placeholder="you@example.com" />
						</div>
						<div class="form-group">
							<label for="password">Password</label>
							<input type="password" id="password" name="password" required placeholder="Your password" />
						</div>
						<button type="submit" class="btn-primary">Login</button>
						<p class="auth-switch">
							Don't have an account? <button type="button" class="link-btn" onclick="switchTab('register')">Register here</button>
						</p>
					</form>
				</div>

				<div id="register-form" class="auth-form hidden">
					<form id="registerForm">
						<div class="form-group">
							<label for="reg-name">Contact Name</label>
							<input type="text" id="reg-name" name="name" required placeholder="Your full name" />
						</div>
						<div class="form-group">
							<label for="reg-business">Maker or Studio Name</label>
							<input type="text" id="reg-business" name="businessName" placeholder="Your startup, studio, or maker name" />
						</div>
						<div class="form-group">
							<label for="reg-email">Email</label>
							<input type="email" id="reg-email" name="email" required placeholder="you@example.com" />
						</div>
						<div class="form-group">
							<label for="reg-phone">Phone</label>
							<input type="tel" id="reg-phone" name="phone" required placeholder="+263 77 123 4567" />
						</div>
						<div class="form-group">
							<label for="reg-password">Password</label>
							<input type="password" id="reg-password" name="password" required minlength="8" placeholder="Min 8 characters" />
						</div>
						<div class="form-group">
							<label for="reg-confirm">Confirm Password</label>
							<input type="password" id="reg-confirm" name="confirmPassword" required placeholder="Repeat password" />
						</div>
						<button type="submit" class="btn-primary">Create Account</button>
						<p class="auth-switch">
							Already have an account? <button type="button" class="link-btn" onclick="switchTab('login')">Login here</button>
						</p>
					</form>
				</div>

				<div id="message" class="message hidden"></div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<script>
	import { isAuthenticated, signInEmailPassword, signUpEmailPassword } from '../../lib/convexAuthClient';

	function setMessage(text: string, type: 'error' | 'success') {
		const messageEl = document.getElementById('message');
		if (!messageEl) return;
		messageEl.textContent = text;
		messageEl.classList.remove('hidden', 'error', 'success');
		messageEl.classList.add(type);
	}

	function switchTab(tab: string) {
		document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
		document.querySelectorAll('.auth-form').forEach(form => form.classList.add('hidden'));
		document.querySelector(`.tab-btn[data-tab="${tab}"]`)?.classList.add('active');
		document.getElementById(`${tab}-form`)?.classList.remove('hidden');
	}

	if (await isAuthenticated()) {
		window.location.href = '/vendor/dashboard';
	}

	document.querySelectorAll('.tab-btn').forEach(btn => {
		btn.addEventListener('click', () => switchTab(btn.getAttribute('data-tab') || 'login'));
	});

	document.getElementById('loginForm')?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const form = e.target as HTMLFormElement;
		const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
		const email = (form.querySelector('#email') as HTMLInputElement).value.trim().toLowerCase();
		const password = (form.querySelector('#password') as HTMLInputElement).value;

		try {
			if (submitButton) submitButton.disabled = true;
			const result = await signInEmailPassword({ email, password });
			if (result?.tokens) {
				window.location.href = '/vendor/dashboard';
				return;
			}
			setMessage('Login failed. Please try again.', 'error');
		} catch (error: any) {
			setMessage(error.message || 'Login failed', 'error');
		} finally {
			if (submitButton) submitButton.disabled = false;
		}
	});

	document.getElementById('registerForm')?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const form = e.target as HTMLFormElement;
		const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
		const name = (form.querySelector('#reg-name') as HTMLInputElement).value.trim();
		const businessName = (form.querySelector('#reg-business') as HTMLInputElement).value.trim();
		const email = (form.querySelector('#reg-email') as HTMLInputElement).value.trim().toLowerCase();
		const phone = (form.querySelector('#reg-phone') as HTMLInputElement).value.trim();
		const password = (form.querySelector('#reg-password') as HTMLInputElement).value;
		const confirmPassword = (form.querySelector('#reg-confirm') as HTMLInputElement).value;
		
		if (password !== confirmPassword) {
			setMessage('Passwords do not match', 'error');
			return;
		}
		
		try {
			if (submitButton) submitButton.disabled = true;
			const result = await signUpEmailPassword({ email, password, name, businessName, phone });
			if (result?.tokens) {
				window.location.href = '/pricing';
				return;
			}
			setMessage('Registration failed. Please try again.', 'error');
		} catch (error: any) {
			setMessage(error.message || 'Registration failed', 'error');
		} finally {
			if (submitButton) submitButton.disabled = false;
		}
	});
</script>

<style>
	.auth-page {
		display: grid;
		place-items: center;
		width: 100%;
		max-width: none;
		min-height: calc(100vh - 180px);
		box-sizing: border-box;
		padding: 2em 1em;
		margin: 0;
	}
	.auth-container {
		width: min(100%, 560px);
		box-sizing: border-box;
		background: white;
		border-radius: 16px;
		padding: clamp(1.5em, 4vw, 2.5em);
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
	}
	.auth-container *,
	.auth-container *::before,
	.auth-container *::after {
		box-sizing: border-box;
	}
	.auth-header {
		text-align: center;
		margin-bottom: 2em;
	}
	.auth-header h1 {
		color: var(--zim-green);
		margin-bottom: 0.5em;
	}
	.auth-header p {
		color: rgb(var(--gray));
	}
	.auth-tabs {
		display: flex;
		gap: 1em;
		margin-bottom: 1.5em;
	}
	.tab-btn {
		flex: 1;
		padding: 0.75em;
		border: 2px solid rgb(var(--gray-light));
		background: transparent;
		color: rgb(var(--gray));
		border-radius: 8px;
		cursor: pointer;
		font-weight: 600;
		transition: all 0.2s;
	}
	.tab-btn.active {
		border-color: var(--zim-green);
		color: var(--zim-green);
		background: rgba(49, 155, 50, 0.1);
	}
	.form-group {
		margin-bottom: 1em;
	}
	.form-group label {
		display: block;
		margin-bottom: 0.5em;
		font-weight: 600;
		color: rgb(var(--gray-dark));
	}
	.form-group input {
		width: 100%;
		padding: 0.75em;
		border: 2px solid rgb(var(--gray-light));
		border-radius: 8px;
		font-size: 1em;
	}
	.form-group input:focus {
		outline: none;
		border-color: var(--zim-green);
	}
	.btn-primary {
		width: 100%;
		padding: 0.75em;
		background: var(--zim-green);
		color: white;
		border: none;
		border-radius: 8px;
		font-size: 1em;
		font-weight: 600;
		cursor: pointer;
		margin-top: 1em;
	}
	.btn-primary:hover {
		background: #1a6b2a;
	}
	.auth-switch {
		text-align: center;
		margin-top: 1.5em;
		color: rgb(var(--gray));
	}
	.link-btn {
		background: none;
		border: none;
		color: var(--zim-green);
		cursor: pointer;
		text-decoration: underline;
		font-weight: 600;
	}
	.hidden {
		display: none;
	}
	.message {
		padding: 1em;
		border-radius: 8px;
		margin-top: 1em;
		text-align: center;
	}
	.message.error {
		background: rgba(215, 20, 61, 0.1);
		color: var(--zim-red);
	}
	.message.success {
		background: rgba(49, 155, 50, 0.1);
		color: var(--zim-green);
	}
</style>
