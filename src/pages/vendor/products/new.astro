---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const categories = [
  { name: 'Electronics', slug: 'electronics' },
  { name: 'Clothing', slug: 'clothing' },
  { name: 'Food & Beverages', slug: 'food' },
  { name: 'Services', slug: 'services' },
  { name: 'Art & Crafts', slug: 'art' },
  { name: 'Health & Beauty', slug: 'health' },
  { name: 'Education', slug: 'education' },
  { name: 'Home & Garden', slug: 'home' },
  { name: 'Other', slug: 'other' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Add Product | GABA Vendor" description="Add a new product to your store" />
	</head>
	<body>
		<Header />
		<main class="product-form-page">
			<div class="form-header">
				<a href="/vendor/dashboard" class="back-link">← Back to Dashboard</a>
				<h1>Add New Product</h1>
			</div>

			<form id="productForm" class="product-form">
				<div class="form-section">
					<h2>Basic Information</h2>
					<div class="form-group">
						<label for="name">Product Name *</label>
						<input type="text" id="name" name="name" required placeholder="Enter product name" />
					</div>
					<div class="form-group">
						<label for="description">Description *</label>
						<textarea id="description" name="description" rows="4" required placeholder="Describe your product..."></textarea>
					</div>
					<div class="form-row">
						<div class="form-group">
							<label for="category">Category *</label>
							<select id="category" name="category" required>
								<option value="">Select a category</option>
								{categories.map(cat => (
									<option value={cat.slug}>{cat.name}</option>
								))}
							</select>
						</div>
						<div class="form-group">
							<label for="stock">Stock Quantity *</label>
							<input type="number" id="stock" name="stock" min="0" value="1" required />
						</div>
					</div>
				</div>

				<div class="form-section">
					<h2>Pricing</h2>
					<div class="form-row">
						<div class="form-group">
							<label for="price">Price *</label>
							<input type="number" id="price" name="price" min="0" step="0.01" required placeholder="0.00" />
						</div>
						<div class="form-group">
							<label for="currency">Currency</label>
							<select id="currency" name="currency">
								<option value="ZWL">ZWL (Zimbabwe Dollar)</option>
								<option value="USD">USD (US Dollar)</option>
							</select>
						</div>
					</div>
				</div>

				<div class="form-section">
					<h2>Links (Optional)</h2>
					<div class="form-group">
						<label for="liveUrl">Live Demo URL</label>
						<input type="url" id="liveUrl" name="liveUrl" placeholder="https://example.com/demo" />
					</div>
					<div class="form-row">
						<div class="form-group">
							<label for="repoUrl">Repository URL</label>
							<input type="url" id="repoUrl" name="repoUrl" placeholder="https://github.com/..." />
						</div>
						<div class="form-group">
							<label for="demoUrl">Additional Demo</label>
							<input type="url" id="demoUrl" name="demoUrl" placeholder="Video demo URL" />
						</div>
					</div>
				</div>

				<div class="form-section">
					<h2>Product Images</h2>
					<div class="image-upload">
						<input type="file" id="images" name="images" accept="image/*" multiple />
						<p class="help-text">Upload product images (max 5MB each)</p>
					</div>
					<div id="imagePreview" class="image-preview"></div>
				</div>

				<div class="form-actions">
					<button type="submit" name="status" value="draft" class="btn-secondary">Save as Draft</button>
					<button type="submit" name="status" value="active" class="btn-primary">Publish Product</button>
				</div>
			</form>
		</main>
		<Footer />
	</body>
</html>

<style>
	.product-form-page {
		max-width: 700px;
		margin: 0 auto;
		padding: 2em 1em;
	}
	.form-header {
		margin-bottom: 2em;
	}
	.back-link {
		color: rgb(var(--gray));
		text-decoration: none;
		font-size: 0.9em;
	}
	.back-link:hover {
		color: var(--zim-green);
	}
	.form-header h1 {
		color: var(--zim-green);
		margin-top: 0.5em;
	}
	.product-form {
		background: white;
		border-radius: 16px;
		padding: 2em;
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
	}
	.form-section {
		margin-bottom: 2em;
		padding-bottom: 2em;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.form-section:last-of-type {
		border-bottom: none;
		margin-bottom: 0;
	}
	.form-section h2 {
		font-size: 1.2em;
		margin-bottom: 1em;
		color: rgb(var(--gray-dark));
	}
	.form-group {
		margin-bottom: 1em;
	}
	.form-group label {
		display: block;
		margin-bottom: 0.5em;
		font-weight: 600;
		color: rgb(var(--gray-dark));
	}
	.form-group input,
	.form-group textarea,
	.form-group select {
		width: 100%;
		padding: 0.75em;
		border: 2px solid rgb(var(--gray-light));
		border-radius: 8px;
		font-size: 1em;
		font-family: inherit;
	}
	.form-group input:focus,
	.form-group textarea:focus,
	.form-group select:focus {
		outline: none;
		border-color: var(--zim-green);
	}
	.form-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1em;
	}
	@media (max-width: 600px) {
		.form-row {
			grid-template-columns: 1fr;
		}
	}
	.image-upload input {
		width: 100%;
		padding: 1em;
		border: 2px dashed rgb(var(--gray-light));
		border-radius: 8px;
	}
	.help-text {
		font-size: 0.85em;
		color: rgb(var(--gray));
		margin-top: 0.5em;
	}
	.image-preview {
		display: flex;
		gap: 1em;
		flex-wrap: wrap;
		margin-top: 1em;
	}
	.form-actions {
		display: flex;
		gap: 1em;
		justify-content: flex-end;
		margin-top: 2em;
	}
	.btn-primary,
	.btn-secondary {
		padding: 0.75em 2em;
		border: none;
		border-radius: 8px;
		font-size: 1em;
		font-weight: 600;
		cursor: pointer;
	}
	.btn-primary {
		background: var(--zim-green);
		color: white;
	}
	.btn-secondary {
		background: rgb(var(--gray-light));
		color: rgb(var(--gray-dark));
	}
	.btn-primary:hover {
		background: #1a6b2a;
	}
	.btn-secondary:hover {
		background: rgb(var(--gray));
		color: white;
	}
</style>

<script>
	const form = document.getElementById('productForm') as HTMLFormElement;
	const imageInput = document.getElementById('images') as HTMLInputElement;
	const imagePreview = document.getElementById('imagePreview');

	imageInput?.addEventListener('change', (e) => {
		const files = (e.target as HTMLInputElement).files;
		if (!files || !imagePreview) return;
		
		imagePreview.innerHTML = '';
		Array.from(files).forEach(file => {
			const reader = new FileReader();
			reader.onload = (e) => {
				const div = document.createElement('div');
				div.style.cssText = 'width: 100px; height: 100px; border-radius: 8px; overflow: hidden;';
				div.innerHTML = `<img src="${e.target?.result}" style="width: 100%; height: 100%; object-fit: cover;" />`;
				imagePreview?.appendChild(div);
			};
			reader.readAsDataURL(file);
		});
	});

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const formData = new FormData(form);
		const status = (e.submitter as HTMLButtonElement).value;
		
		const data = {
			name: formData.get('name'),
			description: formData.get('description'),
			category: formData.get('category'),
			stock: Number(formData.get('stock')),
			price: Number(formData.get('price')),
			currency: formData.get('currency') || 'USD',
			liveUrl: formData.get('liveUrl') || null,
			repoUrl: formData.get('repoUrl') || null,
			demoUrl: formData.get('demoUrl') || null,
			images: [],
			status,
		};

		// In production, this would call Convex mutation
		console.log('Product data:', data);
		
		// For demo, redirect to dashboard
		alert('Product saved! (Demo mode - Convex integration pending)');
		window.location.href = '/vendor/dashboard';
	});
</script>