---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const categories = [
	{ name: 'All Drops', slug: 'all', count: 32 },
	{ name: 'Apps', slug: 'apps', count: 9 },
	{ name: 'AI', slug: 'ai', count: 7 },
	{ name: 'SaaS', slug: 'saas', count: 6 },
	{ name: 'Fintech', slug: 'fintech', count: 5 },
	{ name: 'Hardware', slug: 'hardware', count: 3 },
	{ name: 'Developer Tools', slug: 'developer-tools', count: 2 },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Drops | GABA" description="Weekly African tech product drops, maker launches, and editorial picks." />
	</head>
	<body>
		<Header />
		<section class="launch-stats" aria-label="Drop statistics">
			<div class="stats-grid">
				<div class="stat-card">
					<span>This Week</span>
					<strong class="mono">32</strong>
				</div>
				<div class="stat-card">
					<span>Editorial Picks</span>
					<strong class="mono">8</strong>
				</div>
				<div class="stat-card">
					<span>Review Queue</span>
					<strong class="mono">21</strong>
				</div>
				<div class="stat-card">
					<span>Open Source</span>
					<strong class="mono">6</strong>
				</div>
			</div>
		</section>
		<main>
			<div class="terminal-layout">
				<aside class="sidebar">
					<section>
						<h3>Drop View</h3>
						<div class="filter-list">
							{categories.map((cat) => (
								<button class:list={['filter-link', { active: cat.slug === 'all' }]} data-category={cat.slug}>
									<span>{cat.name}</span>
									<span>{cat.count}</span>
								</button>
							))}
						</div>
					</section>
					<section class="distribution-card">
						<h4>Drop Quality</h4>
						<div class="metric-row">
							<span>States clear problem</span>
							<strong class="mono">100%</strong>
						</div>
						<div class="progress"><span style="width: 100%"></span></div>
						<div class="metric-row">
							<span>Has live URL</span>
							<strong class="mono">82%</strong>
						</div>
						<div class="progress muted"><span style="width: 82%"></span></div>
					</section>
					<section class="report-card">
						<h4>Weekly Featured Drops</h4>
						<p>Editorial picks highlight products with a clear problem, a real maker, and a specific African market context.</p>
						<a href="/vendor/products/new">Submit Product →</a>
					</section>
				</aside>

				<section class="terminal-main">
					<div class="terminal-heading">
						<div>
							<p class="eyebrow">New and notable African tech</p>
							<h1>Drops</h1>
							<p>Fresh products from African makers, ranked by community signal and reviewed for context.</p>
						</div>
						<form class="page-search">
							<span>⌕</span>
							<input type="search" id="search" placeholder="Search drops, makers, countries..." />
						</form>
					</div>

					<div class="launch-table-shell">
						<table class="launch-table">
							<thead>
								<tr>
									<th>Product</th>
									<th>Problem</th>
									<th>Country</th>
									<th>Category</th>
									<th>Status</th>
									<th>Maker</th>
									<th>Upvotes</th>
									<th></th>
								</tr>
							</thead>
							<tbody id="launches-body">
								<tr>
									<td colspan="8" class="loading-cell">Loading weekly drops...</td>
								</tr>
							</tbody>
						</table>
						<div class="list-footer">
							<a href="/vendor/products/new">Submit New Product</a>
						</div>
					</div>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.launch-stats {
		border-bottom: 1px solid var(--ui-border);
		background: white;
	}
	.stats-grid {
		display: grid;
		width: min(1400px, 100%);
		margin: 0 auto;
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}
	.stat-card {
		padding: 1.5rem;
		border-right: 1px solid var(--ui-border);
	}
	.stat-card:last-child {
		border-right: 0;
	}
	.stat-card span {
		display: block;
		margin-bottom: 0.35rem;
		color: #94a3b8;
		font-size: 10px;
		font-weight: 900;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}
	.stat-card strong {
		color: #0f172a;
		font-size: 1.5rem;
		font-weight: 650;
	}
	main {
		width: min(1400px, calc(100% - 3rem));
		max-width: none;
		padding: 3rem 0;
	}
	.terminal-layout {
		display: grid;
		grid-template-columns: 280px minmax(0, 1fr);
		gap: 3rem;
	}
	.sidebar {
		display: grid;
		align-content: start;
		gap: 2rem;
	}
	.sidebar h3 {
		margin: 0 0 1rem;
		color: #94a3b8;
		font-size: 11px;
		font-weight: 950;
		letter-spacing: 0.2em;
		text-transform: uppercase;
	}
	.filter-list {
		display: grid;
		gap: 0.25rem;
	}
	.filter-link {
		display: flex;
		justify-content: space-between;
		align-items: center;
		width: 100%;
		padding: 0.55rem 0.75rem;
		border: 0;
		border-radius: 4px;
		background: transparent;
		color: #475569;
		cursor: pointer;
		font: inherit;
		font-size: 0.88rem;
		font-weight: 700;
		text-align: left;
	}
	.filter-link:hover {
		background: #f1f5f9;
		color: #0f172a;
	}
	.filter-link.active {
		border: 1px solid #d1fae5;
		background: #ecfdf5;
		color: #047857;
	}
	.distribution-card,
	.report-card {
		border: 1px solid var(--ui-border);
		border-radius: 8px;
		background: white;
		padding: 1.25rem;
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
	}
	.distribution-card h4,
	.report-card h4 {
		margin: 0 0 1rem;
		color: #0f172a;
		font-size: 11px;
		font-weight: 950;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}
	.metric-row {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		margin: 0.9rem 0 0.35rem;
		color: #475569;
		font-size: 12px;
	}
	.metric-row strong {
		color: #0f172a;
	}
	.progress {
		height: 4px;
		overflow: hidden;
		border-radius: 99px;
		background: #f1f5f9;
	}
	.progress span {
		display: block;
		height: 100%;
		background: var(--accent);
	}
	.progress.muted span {
		background: #94a3b8;
	}
	.report-card {
		border-color: #0f172a;
		background: #0f172a;
		color: white;
	}
	.report-card p {
		margin: 0 0 1rem;
		color: #94a3b8;
		font-size: 12px;
		line-height: 1.7;
	}
	.report-card a {
		color: #34d399;
		font-size: 10px;
		font-weight: 950;
		letter-spacing: 0.12em;
		text-decoration: none;
		text-transform: uppercase;
	}
	.eyebrow {
		margin: 0 0 0.8rem;
		color: var(--accent);
		font-size: 0.72rem;
		font-weight: 950;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}
	.terminal-heading {
		display: flex;
		justify-content: space-between;
		align-items: end;
		gap: 1rem;
		margin-bottom: 2rem;
	}
	.terminal-heading h1 {
		margin-bottom: 0.35rem;
		color: #0f172a;
		font-size: clamp(2rem, 5vw, 3rem);
		font-weight: 850;
		letter-spacing: -0.04em;
	}
	.terminal-heading p:last-child {
		margin: 0;
		color: #64748b;
		font-size: 0.92rem;
	}
	.page-search {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		min-height: 42px;
		width: min(100%, 380px);
		padding: 0 0.8rem;
		border: 1px solid var(--ui-border);
		border-radius: 4px;
		background: white;
		color: #94a3b8;
	}
	.page-search input {
		width: 100%;
		border: 0;
		outline: 0;
		background: transparent;
		color: #0f172a;
		font: inherit;
		font-size: 13px;
		font-weight: 700;
	}
	.launch-table-shell {
		overflow-x: auto;
		border: 1px solid var(--ui-border);
		border-radius: 12px;
		background: white;
	}
	.launch-table {
		width: 100%;
		min-width: 1120px;
		border-collapse: collapse;
	}
	.launch-table th {
		padding: 1.05rem 1rem;
		background: #f8fafc;
		color: #64748b;
		font-size: 0.72rem;
		font-weight: 900;
		letter-spacing: 0.12em;
		text-align: left;
		text-transform: uppercase;
	}
	.launch-table td {
		padding: 1.05rem 1rem;
		border-top: 1px solid #eef2f7;
		color: #43536b;
		font-size: 0.92rem;
		font-weight: 650;
		vertical-align: middle;
	}
	.launch-table tr:hover td {
		background: #fbfdff;
	}
	.product-cell {
		display: flex;
		align-items: center;
		gap: 0.9rem;
		color: inherit;
		text-decoration: none;
	}
	.avatar {
		display: grid;
		width: 42px;
		height: 42px;
		flex: 0 0 42px;
		place-items: center;
		border: 1px solid #dbe4f0;
		border-radius: 10px;
		background: #f8fafc;
		color: #0f172a;
		font-size: 0.8rem;
		font-weight: 900;
	}
	.product-cell strong {
		display: block;
		color: #0f172a;
		font-size: 1rem;
		font-weight: 900;
		letter-spacing: -0.02em;
	}
	.product-cell small {
		display: block;
		max-width: 260px;
		overflow: hidden;
		color: #64748b;
		font-size: 0.76rem;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	.problem-cell {
		max-width: 300px;
		white-space: normal;
	}
	.category-pill {
		display: inline-flex;
		padding: 0.35rem 0.75rem;
		border-radius: 999px;
		background: #f1f5f9;
		color: #40536d;
		font-size: 0.8rem;
		font-weight: 750;
	}
	.status-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.38rem;
		color: #059669;
		font-size: 11px;
		font-weight: 950;
		text-transform: uppercase;
	}
	.status-pill i {
		width: 6px;
		height: 6px;
		border-radius: 99px;
		background: #10b981;
	}
	.upvote-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.35rem 0.6rem;
		border: 1px solid #dbe4f0;
		border-radius: 999px;
		background: white;
		color: #0f172a;
		cursor: pointer;
		font: inherit;
		font-size: 0.78rem;
		font-weight: 900;
	}
	.upvote-btn:hover {
		border-color: #a7f3d0;
		background: #ecfdf5;
		color: #047857;
	}
	.upvote-btn.is-voted {
		border-color: var(--accent);
		background: #f0fdf4;
		color: var(--accent);
		box-shadow: 0 0 0 1px rgba(5, 150, 105, 0.08);
	}
	.upvote-btn.is-voted:hover {
		border-color: var(--accent);
		background: #ecfdf5;
		color: var(--accent);
	}
	.upvote-btn.vote-pop {
		animation: vote-pop 240ms ease;
	}
	@keyframes vote-pop {
		0% {
			transform: scale(1);
		}
		45% {
			transform: scale(1.06);
		}
		100% {
			transform: scale(1);
		}
	}
	.open-link {
		color: #cbd5e1;
		font-size: 1.5rem;
		text-decoration: none;
	}
	.launch-table tr:hover .open-link {
		color: #0f172a;
	}
	.loading-cell,
	.empty-cell {
		padding: 3rem 1rem;
		color: #94a3b8;
		text-align: center;
	}
	.list-footer {
		display: flex;
		justify-content: center;
		padding: 1rem;
	}
	.list-footer a {
		color: #64748b;
		font-size: 11px;
		font-weight: 950;
		letter-spacing: 0.12em;
		text-decoration: none;
		text-transform: uppercase;
	}
	.list-footer a:hover {
		color: #0f172a;
	}
	@media (max-width: 980px) {
		.stats-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
		.terminal-layout {
			grid-template-columns: 1fr;
		}
		.sidebar {
			grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		}
	}
	@media (max-width: 640px) {
		.stats-grid {
			grid-template-columns: 1fr;
		}
		.stat-card {
			border-right: 0;
			border-bottom: 1px solid var(--ui-border);
		}
		main {
			width: min(100% - 1.5rem, 1400px);
			padding: 2rem 0;
		}
		.terminal-heading {
			display: grid;
		}
		.page-search {
			width: auto;
		}
	}
</style>

<script>
	import { ConvexHttpClient } from 'convex/browser';

	type Product = {
		_id?: string;
		name: string;
		description: string;
		tagline?: string;
		problemSolved?: string;
		country?: string;
		category: string;
		makerName?: string;
		makerLocation?: string;
		liveUrl?: string | null;
		demoUrl?: string | null;
		repoUrl?: string | null;
		productStatus?: string;
		status: string;
		upvoteCount?: number;
		createdAt?: number;
	};

	const categoryLabels: Record<string, string> = {
		apps: 'Apps',
		ai: 'AI',
		hardware: 'Hardware',
		saas: 'SaaS',
		'developer-tools': 'Developer Tools',
		fintech: 'Fintech',
		edtech: 'Edtech',
		gadgets: 'Gadgets',
		other: 'Other',
	};

	const statusLabels: Record<string, string> = {
		beta: 'Beta',
		live: 'Live',
		'open-source': 'Open Source',
		hiring: 'Hiring',
	};

	const sampleDrops: Product[] = [
		{ _id: 'seed-1', name: 'FarmFresh App', tagline: 'Fresh produce logistics for local buyers', description: 'Mobile commerce and logistics for local farm supply chains.', problemSolved: 'Helps restaurants and households buy reliable farm produce from nearby growers.', country: 'Zimbabwe', category: 'apps', makerName: 'Farai Moyo', makerLocation: 'Harare', liveUrl: '/projects/farmfresh-app', productStatus: 'live', status: 'active', upvoteCount: 148 },
		{ _id: 'seed-2', name: 'EcoCar Zim', tagline: 'EV charging discovery for Zimbabwe', description: 'EV charging discovery and mobility intelligence for Zimbabwe.', problemSolved: 'Shows drivers where charging options exist before buying or operating an EV.', country: 'Zimbabwe', category: 'saas', makerName: 'Tariro Labs', makerLocation: 'Harare', liveUrl: '/projects/ecocar-zim', productStatus: 'beta', status: 'active', upvoteCount: 96 },
		{ _id: 'seed-3', name: 'Mbare Market Hub', tagline: 'Trading tools for informal commerce', description: 'Commerce dashboard for informal trader inventory and payments.', problemSolved: 'Gives market traders a simple way to track stock, sales, and mobile payments.', country: 'Zimbabwe', category: 'fintech', makerName: 'Harare Lab', makerLocation: 'Mbare', liveUrl: '/vendor', productStatus: 'beta', status: 'active', upvoteCount: 81 },
		{ _id: 'seed-4', name: 'Shona AI Tools', tagline: 'Language tools for Shona support teams', description: 'Language tooling prototypes for local customer support and content.', problemSolved: 'Helps teams answer customers and create content in local language contexts.', country: 'Zimbabwe', category: 'ai', makerName: 'Nyasha Code Studio', makerLocation: 'Bulawayo', liveUrl: '/launches', productStatus: 'open-source', status: 'active', upvoteCount: 73 },
	];

	const searchInput = document.getElementById('search') as HTMLInputElement | null;
	const filterButtons = document.querySelectorAll('.filter-link');
	const launchesBody = document.getElementById('launches-body');
	let allDrops: Product[] = [];

	function escapeHtml(value: unknown) {
		return String(value ?? '')
			.replaceAll('&', '&amp;')
			.replaceAll('<', '&lt;')
			.replaceAll('>', '&gt;')
			.replaceAll('"', '&quot;')
			.replaceAll("'", '&#039;');
	}

	function initials(name: string) {
		return name
			.split(/\s+/)
			.filter(Boolean)
			.slice(0, 2)
			.map((part) => part[0]?.toUpperCase())
			.join('');
	}

	function primaryUrl(product: Product) {
		return product.liveUrl || product.demoUrl || product.repoUrl || '/vendor/products/new';
	}

	function renderDrops() {
		if (!launchesBody) return;
		const activeCategory = document.querySelector('.filter-link.active')?.getAttribute('data-category');
		const searchTerm = searchInput?.value.toLowerCase() || '';
		const filtered = allDrops.filter((product) => {
			const label = categoryLabels[product.category] || product.category;
			const matchesCategory = activeCategory === 'all' || product.category === activeCategory;
			const searchable = `${product.name} ${product.tagline || ''} ${product.problemSolved || ''} ${product.country || ''} ${product.makerName || ''} ${label}`.toLowerCase();
			return matchesCategory && searchable.includes(searchTerm) && product.status === 'active';
		});

		if (filtered.length === 0) {
			launchesBody.innerHTML = '<tr><td colspan="8" class="empty-cell">No drops match this view yet.</td></tr>';
			return;
		}

		launchesBody.innerHTML = filtered
			.map((product) => {
				const href = primaryUrl(product);
				const label = categoryLabels[product.category] || product.category;
				const status = statusLabels[product.productStatus || 'live'] || product.productStatus || 'Live';
				return `
					<tr>
						<td>
							<a href="${escapeHtml(href)}" class="product-cell" ${href.startsWith('http') ? 'target="_blank" rel="noreferrer"' : ''}>
								<span class="avatar">${escapeHtml(initials(product.name))}</span>
								<span>
									<strong>${escapeHtml(product.name)}</strong>
									<small>${escapeHtml(product.tagline || product.description)}</small>
								</span>
							</a>
						</td>
						<td class="problem-cell">${escapeHtml(product.problemSolved || product.description)}</td>
						<td>${escapeHtml(product.country || 'Zimbabwe')}</td>
						<td><span class="category-pill">${escapeHtml(label)}</span></td>
						<td><span class="status-pill"><i></i>${escapeHtml(status)}</span></td>
						<td>${escapeHtml(product.makerName || 'Independent Maker')}</td>
						<td><button type="button" class="upvote-btn" data-product-id="${escapeHtml(product._id || '')}">▲ <span>${escapeHtml(product.upvoteCount || 0)}</span></button></td>
						<td><a href="${escapeHtml(href)}" class="open-link" ${href.startsWith('http') ? 'target="_blank" rel="noreferrer"' : ''}>→</a></td>
					</tr>
				`;
			})
			.join('');

		document.querySelectorAll<HTMLButtonElement>('.upvote-btn').forEach((button) => {
			button.addEventListener('click', async () => {
				const productId = button.dataset.productId;
				if (!productId || productId.startsWith('seed-')) {
					const count = button.querySelector('span');
					const voted = button.dataset.voted === 'true';
					const nextCount = voted ? Math.max(Number(count?.textContent || 0) - 1, 0) : Number(count?.textContent || 0) + 1;
					if (count) count.textContent = String(nextCount);
					button.dataset.voted = String(!voted);
					button.classList.toggle('is-voted', !voted);
					button.setAttribute('aria-pressed', String(!voted));
					button.classList.remove('vote-pop');
					void button.offsetWidth;
					button.classList.add('vote-pop');
					return;
				}
				try {
					const { convexMutation } = await import('../../lib/convexAuthClient');
					const result = await convexMutation('products:upvote', { productId });
					const count = button.querySelector('span');
					if (count && result?.upvoteCount !== undefined) count.textContent = String(result.upvoteCount);
					const voted = Boolean(result?.voted);
					button.dataset.voted = String(voted);
					button.classList.toggle('is-voted', voted);
					button.setAttribute('aria-pressed', String(voted));
					button.classList.remove('vote-pop');
					void button.offsetWidth;
					button.classList.add('vote-pop');
				} catch (error: any) {
					alert(error?.message || 'Sign in to upvote products.');
				}
			});
		});
	}

	async function loadDrops() {
		const convexUrl = import.meta.env.PUBLIC_GABA_CONVEX_URL;
		if (!convexUrl) {
			allDrops = sampleDrops;
			renderDrops();
			return;
		}

		try {
			const client = new ConvexHttpClient(convexUrl);
			const products = await client.query('products:list' as never, {} as never);
			allDrops = Array.isArray(products) && products.length > 0 ? products as Product[] : sampleDrops;
		} catch {
			allDrops = sampleDrops;
		}
		renderDrops();
	}

	searchInput?.addEventListener('input', renderDrops);
	filterButtons.forEach((button) => {
		button.addEventListener('click', () => {
			filterButtons.forEach((item) => item.classList.remove('active'));
			button.classList.add('active');
			renderDrops();
		});
	});

	loadDrops();
</script>
