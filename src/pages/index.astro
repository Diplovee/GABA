---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const categories = [
	{ name: 'All Categories', slug: 'all' },
	{ name: 'AI', slug: 'ai' },
	{ name: 'Apps', slug: 'apps' },
	{ name: 'Developer Tools', slug: 'developer-tools' },
	{ name: 'Fintech', slug: 'fintech' },
	{ name: 'Hardware', slug: 'hardware' },
	{ name: 'SaaS', slug: 'saas' },
];

const countries = ['All Countries', 'Zimbabwe', 'South Africa', 'Kenya', 'Nigeria', 'Rwanda'];
const statuses = ['All Statuses', 'Beta', 'Live', 'Open Source', 'Hiring'];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="today-page">
			<section class="today-header" aria-labelledby="today-title">
				<p class="eyebrow">Zimbabwe-first. Africa-wide.</p>
				<h1 id="today-title">Top Products Launching Today</h1>
				<p class="intro">
					For the first 4 hours of the day, GABA hides ranking pressure so every African tech product gets a real chance to catch your interest.
					<a href="/about">Read more</a>
				</p>
			</section>

			<section class="search-panel" aria-label="Search and filter products">
				<div class="search-field">
					<span aria-hidden="true">⌕</span>
					<input type="search" id="search" placeholder="Search products, makers, problems, countries..." />
				</div>
				<div class="filter-row">
					<label>
						<span>Category</span>
						<select id="category-filter">
							{categories.map((category) => (
								<option value={category.slug}>{category.name}</option>
							))}
						</select>
					</label>
					<label>
						<span>Country</span>
						<select id="country-filter">
							{countries.map((country) => (
								<option value={country === 'All Countries' ? 'all' : country}>{country}</option>
							))}
						</select>
					</label>
					<label>
						<span>Status</span>
						<select id="status-filter">
							{statuses.map((status) => (
								<option value={status === 'All Statuses' ? 'all' : status.toLowerCase().replaceAll(' ', '-')}>{status}</option>
							))}
						</select>
					</label>
				</div>
			</section>

			<section class="product-feed" aria-label="Top products">
				<div id="products-list" class="products-list">
					<div class="loading-state">Loading African tech products...</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.today-page {
		width: min(1280px, calc(100% - 3rem));
		max-width: none;
		padding: clamp(2.4rem, 5vw, 4.5rem) 0 4rem;
	}
	.today-header {
		margin-bottom: 2rem;
	}
	.eyebrow {
		margin: 0 0 0.85rem;
		color: var(--accent);
		font-size: 0.72rem;
		font-weight: 950;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}
	h1 {
		max-width: 900px;
		margin: 0;
		color: #111827;
		font-size: clamp(2.15rem, 4vw, 3.2rem);
		font-weight: 900;
		letter-spacing: -0.035em;
		line-height: 1.04;
	}
	.intro {
		max-width: 1080px;
		margin: 1.8rem 0 0;
		color: #334155;
		font-size: clamp(1.02rem, 1.8vw, 1.28rem);
		line-height: 1.65;
	}
	.intro a {
		color: inherit;
		text-decoration-thickness: 1px;
		text-underline-offset: 4px;
	}
	.search-panel {
		display: grid;
		gap: 0.75rem;
		margin-bottom: 2.2rem;
		padding: 1rem;
		border: 1px solid #e5e7eb;
		border-radius: 18px;
		background: white;
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
	}
	.search-field {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		min-height: 48px;
		padding: 0 0.9rem;
		border: 1px solid #e5e7eb;
		border-radius: 12px;
		background: #f8fafc;
		color: #64748b;
	}
	.search-field input {
		width: 100%;
		border: 0;
		outline: 0;
		background: transparent;
		color: #111827;
		font: inherit;
		font-size: 0.98rem;
		font-weight: 650;
	}
	.filter-row {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.75rem;
	}
	.filter-row label {
		display: grid;
		gap: 0.35rem;
	}
	.filter-row label span {
		color: #64748b;
		font-size: 0.68rem;
		font-weight: 950;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}
	.filter-row select {
		width: 100%;
		min-height: 42px;
		padding: 0 0.75rem;
		border: 1px solid #e5e7eb;
		border-radius: 12px;
		background: white;
		color: #111827;
		font: inherit;
		font-size: 0.92rem;
		font-weight: 750;
	}
	.products-list {
		display: grid;
		gap: 1.35rem;
	}
	:global(.product-row) {
		display: grid;
		grid-template-columns: 72px minmax(0, 1fr) 82px 82px;
		gap: 1.5rem;
		align-items: center;
		padding: 0.55rem 0;
	}
	:global(.product-logo) {
		display: grid;
		width: 64px;
		height: 64px;
		place-items: center;
		border: 1px solid #e2e8f0;
		border-radius: 15px;
		background: #f8fafc;
		color: #111827;
		font-size: 0.88rem;
		font-weight: 950;
		letter-spacing: -0.03em;
		overflow: hidden;
		text-decoration: none;
	}
	:global(.product-logo img) {
		width: 100%;
		height: 100%;
		border-radius: 0;
		object-fit: cover;
	}
	:global(.product-main) {
		min-width: 0;
	}
	:global(.product-title-line) {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		flex-wrap: wrap;
	}
	:global(.product-title-line a) {
		color: #111827;
		font-size: 1.08rem;
		font-weight: 900;
		letter-spacing: -0.02em;
		text-decoration: none;
	}
	:global(.product-title-line a:hover) {
		color: var(--accent);
	}
	:global(.pitch-badge) {
		display: inline-flex;
		align-items: center;
		min-height: 22px;
		padding: 0 0.55rem;
		border-radius: 999px;
		background: #eef2ff;
		color: #111827;
		font-size: 0.68rem;
		font-weight: 950;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	:global(.product-tagline) {
		margin: 0.25rem 0 0;
		color: #334155;
		font-size: 1.02rem;
		line-height: 1.45;
	}
	:global(.product-meta) {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		flex-wrap: wrap;
		margin-top: 0.6rem;
		color: #111827;
		font-size: 0.9rem;
		font-weight: 700;
	}
	:global(.product-meta svg) {
		width: 17px;
		height: 17px;
		color: #64748b;
	}
	:global(.dot) {
		color: #cbd5e1;
	}
	:global(.icon-count),
	:global(.upvote-btn) {
		display: grid;
		width: 66px;
		height: 66px;
		place-items: center;
		border: 2px solid #e5e7eb;
		border-radius: 17px;
		background: white;
		color: #334155;
		font: inherit;
		font-size: 1.05rem;
		font-weight: 850;
		line-height: 1.1;
	}
	:global(.icon-count svg),
	:global(.upvote-btn svg) {
		width: 22px;
		height: 22px;
	}
	:global(.icon-count) {
		gap: 0.2rem;
	}
	:global(.upvote-btn) {
		cursor: pointer;
	}
	:global(.upvote-btn:hover) {
		border-color: #a7f3d0;
		background: #ecfdf5;
		color: #047857;
	}
	:global(.upvote-btn.is-voted) {
		border-color: var(--accent);
		background: #f0fdf4;
		color: var(--accent);
		box-shadow: 0 0 0 1px rgba(5, 150, 105, 0.08);
	}
	:global(.upvote-btn.is-voted:hover) {
		border-color: var(--accent);
		background: #ecfdf5;
		color: var(--accent);
	}
	:global(.upvote-btn.vote-pop) {
		animation: vote-pop 240ms ease;
	}
	@keyframes vote-pop {
		0% {
			transform: scale(1);
		}
		45% {
			transform: scale(1.06);
		}
		100% {
			transform: scale(1);
		}
	}
	.loading-state,
	:global(.empty-state) {
		padding: 3rem 1rem;
		color: #64748b;
		text-align: center;
	}
	@media (max-width: 860px) {
		.today-page {
			width: min(100% - 1.5rem, 1280px);
			padding-top: 2rem;
		}
		.filter-row {
			grid-template-columns: 1fr;
		}
		:global(.product-row) {
			grid-template-columns: 56px minmax(0, 1fr) 58px;
			gap: 0.9rem;
			padding: 0.85rem 0;
		}
		:global(.product-logo) {
			width: 52px;
			height: 52px;
			border-radius: 13px;
		}
		:global(.icon-count) {
			display: none;
		}
		:global(.upvote-btn) {
			width: 54px;
			height: 58px;
			border-radius: 15px;
			font-size: 0.92rem;
		}
		:global(.product-title-line a) {
			font-size: 1rem;
		}
		:global(.product-tagline) {
			font-size: 0.94rem;
		}
	}
</style>

<script>
	import { ConvexHttpClient } from 'convex/browser';

	type Product = {
		_id?: string;
		name: string;
		description: string;
		tagline?: string;
		problemSolved?: string;
		country?: string;
		category: string;
		makerName?: string;
		makerLocation?: string;
		logo?: string;
		liveUrl?: string | null;
		demoUrl?: string | null;
		repoUrl?: string | null;
		productStatus?: string;
		status: string;
		upvoteCount?: number;
		commentCount?: number;
		launchAt?: number;
	};

	const categoryLabels: Record<string, string> = {
		apps: 'Apps',
		ai: 'AI',
		hardware: 'Hardware',
		saas: 'SaaS',
		'developer-tools': 'Developer Tools',
		fintech: 'Fintech',
		edtech: 'Edtech',
		gadgets: 'Gadgets',
		other: 'Other',
	};

	const statusLabels: Record<string, string> = {
		beta: 'Beta',
		live: 'Live',
		'open-source': 'Open Source',
		hiring: 'Hiring',
	};

	const sampleProducts: Product[] = [
		{ _id: 'seed-1', name: 'FarmFresh App', tagline: 'Fresh produce logistics for local buyers', description: 'Mobile commerce and logistics for local farm supply chains.', problemSolved: 'Helps restaurants and households buy reliable farm produce from nearby growers.', country: 'Zimbabwe', category: 'apps', makerName: 'Farai Moyo', makerLocation: 'Harare', liveUrl: '/projects/farmfresh-app', productStatus: 'live', status: 'active', upvoteCount: 148, commentCount: 12, launchAt: Date.now() + 2 * 60 * 60 * 1000 },
		{ _id: 'seed-2', name: 'EcoCar Zim', tagline: 'EV charging discovery and routing for Zimbabwe', description: 'EV charging discovery and mobility intelligence for Zimbabwe.', problemSolved: 'Shows drivers where charging options exist before buying or operating an EV.', country: 'Zimbabwe', category: 'saas', makerName: 'Tariro Labs', makerLocation: 'Harare', liveUrl: '/projects/ecocar-zim', productStatus: 'beta', status: 'active', upvoteCount: 96, commentCount: 8, launchAt: Date.now() + 24 * 60 * 60 * 1000 },
		{ _id: 'seed-3', name: 'Mbare Market Hub', tagline: 'Inventory and mobile payments for informal traders', description: 'Commerce dashboard for informal trader inventory and payments.', problemSolved: 'Gives market traders a simple way to track stock, sales, and mobile payments.', country: 'Zimbabwe', category: 'fintech', makerName: 'Harare Lab', makerLocation: 'Mbare', liveUrl: '/vendor', productStatus: 'beta', status: 'active', upvoteCount: 81, commentCount: 5, launchAt: Date.now() - 3 * 60 * 60 * 1000 },
		{ _id: 'seed-4', name: 'Shona AI Tools', tagline: 'Language tooling prototypes for local support and content', description: 'Language tooling prototypes for local customer support and content.', problemSolved: 'Helps teams answer customers and create content in local language contexts.', country: 'Zimbabwe', category: 'ai', makerName: 'Nyasha Code Studio', makerLocation: 'Bulawayo', liveUrl: '/', productStatus: 'open-source', status: 'active', upvoteCount: 73, commentCount: 15, launchAt: Date.now() + 3 * 24 * 60 * 60 * 1000 },
	];

	const searchInput = document.getElementById('search') as HTMLInputElement | null;
	const categoryFilter = document.getElementById('category-filter') as HTMLSelectElement | null;
	const countryFilter = document.getElementById('country-filter') as HTMLSelectElement | null;
	const statusFilter = document.getElementById('status-filter') as HTMLSelectElement | null;
	const productsList = document.getElementById('products-list');
	let allProducts: Product[] = [];

	const initialQuery = new URLSearchParams(window.location.search).get('q');
	if (searchInput && initialQuery) {
		searchInput.value = initialQuery;
	}

	function escapeHtml(value: unknown) {
		return String(value ?? '')
			.replaceAll('&', '&amp;')
			.replaceAll('<', '&lt;')
			.replaceAll('>', '&gt;')
			.replaceAll('"', '&quot;')
			.replaceAll("'", '&#039;');
	}

	function initials(name: string) {
		return name
			.split(/\s+/)
			.filter(Boolean)
			.slice(0, 2)
			.map((part) => part[0]?.toUpperCase())
			.join('');
	}

	function primaryUrl(product: Product) {
		return product.liveUrl || product.demoUrl || product.repoUrl || '/vendor/products/new';
	}

	function tagIcon() {
		return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/></svg>';
	}

	function commentIcon() {
		return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8z"/></svg>';
	}

	function upvoteIcon() {
		return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 5 7 12H5z"/></svg>';
	}

	function launchLabel(product: Product) {
		if (!product.launchAt) {
			return statusLabels[product.productStatus || 'live'] || product.productStatus || 'Live';
		}

		const launchDate = new Date(product.launchAt);
		const now = new Date();
		const sameDay = launchDate.toDateString() === now.toDateString();
		const time = launchDate.toLocaleTimeString('en-GB', {
			hour: '2-digit',
			minute: '2-digit',
		});

		if (product.launchAt > Date.now()) {
			return sameDay ? `Launching today ${time}` : `Launching ${launchDate.toLocaleDateString('en-GB', { month: 'short', day: 'numeric' })}`;
		}

		return sameDay ? `Launched today ${time}` : `Launched ${launchDate.toLocaleDateString('en-GB', { month: 'short', day: 'numeric' })}`;
	}

	function renderProducts() {
		if (!productsList) return;
		const activeCategory = categoryFilter?.value || 'all';
		const activeCountry = countryFilter?.value || 'all';
		const activeStatus = statusFilter?.value || 'all';
		const searchTerm = searchInput?.value.toLowerCase() || '';
		const filtered = allProducts.filter((product) => {
			const label = categoryLabels[product.category] || product.category;
			const status = product.productStatus || 'live';
			const matchesCategory = activeCategory === 'all' || product.category === activeCategory;
			const matchesCountry = activeCountry === 'all' || product.country === activeCountry;
			const matchesStatus = activeStatus === 'all' || status === activeStatus;
			const searchable = `${product.name} ${product.tagline || ''} ${product.problemSolved || ''} ${product.country || ''} ${product.makerName || ''} ${label}`.toLowerCase();
			return matchesCategory && matchesCountry && matchesStatus && searchable.includes(searchTerm) && product.status === 'active';
		});

		if (filtered.length === 0) {
			productsList.innerHTML = '<div class="empty-state">No products match this view yet.</div>';
			return;
		}

		productsList.innerHTML = filtered
			.map((product) => {
				const href = primaryUrl(product);
				const label = categoryLabels[product.category] || product.category;
				const status = launchLabel(product);
				const logo = product.logo
					? `<img src="${escapeHtml(product.logo)}" alt="" />`
					: escapeHtml(initials(product.name));
				return `
					<article class="product-row">
						<a href="${escapeHtml(href)}" class="product-logo" ${href.startsWith('http') ? 'target="_blank" rel="noreferrer"' : ''}>${logo}</a>
						<div class="product-main">
							<div class="product-title-line">
								<a href="${escapeHtml(href)}" ${href.startsWith('http') ? 'target="_blank" rel="noreferrer"' : ''}>${escapeHtml(product.name)}</a>
								<span class="pitch-badge">${escapeHtml(status)}</span>
							</div>
							<p class="product-tagline">${escapeHtml(product.tagline || product.problemSolved || product.description)}</p>
							<div class="product-meta">
								${tagIcon()}
								<span>${escapeHtml(product.country || 'Zimbabwe')}</span>
								<span class="dot">•</span>
								<span>${escapeHtml(label)}</span>
								<span class="dot">•</span>
								<span>${escapeHtml(product.makerName || 'Independent Maker')}</span>
							</div>
						</div>
						<div class="icon-count">${commentIcon()}<span>${escapeHtml(product.commentCount || 0)}</span></div>
						<button type="button" class="upvote-btn" data-product-id="${escapeHtml(product._id || '')}">
							${upvoteIcon()}
							<span>${escapeHtml(product.upvoteCount || 0)}</span>
						</button>
					</article>
				`;
			})
			.join('');

		document.querySelectorAll<HTMLButtonElement>('.upvote-btn').forEach((button) => {
			button.addEventListener('click', async () => {
				const productId = button.dataset.productId;
				if (!productId || productId.startsWith('seed-')) {
					const count = button.querySelector('span');
					const voted = button.dataset.voted === 'true';
					const nextCount = voted ? Math.max(Number(count?.textContent || 0) - 1, 0) : Number(count?.textContent || 0) + 1;
					if (count) count.textContent = String(nextCount);
					button.dataset.voted = String(!voted);
					button.classList.toggle('is-voted', !voted);
					button.setAttribute('aria-pressed', String(!voted));
					button.classList.remove('vote-pop');
					void button.offsetWidth;
					button.classList.add('vote-pop');
					return;
				}
				try {
					const { convexMutation } = await import('../lib/convexAuthClient');
					const result = await convexMutation('products:upvote', { productId });
					const count = button.querySelector('span');
					if (count && result?.upvoteCount !== undefined) count.textContent = String(result.upvoteCount);
					const voted = Boolean(result?.voted);
					button.dataset.voted = String(voted);
					button.classList.toggle('is-voted', voted);
					button.setAttribute('aria-pressed', String(voted));
					button.classList.remove('vote-pop');
					void button.offsetWidth;
					button.classList.add('vote-pop');
				} catch (error: any) {
					alert(error?.message || 'Sign in to upvote products.');
				}
			});
		});
	}

	async function loadProducts() {
		const convexUrl = import.meta.env.PUBLIC_GABA_CONVEX_URL;
		if (!convexUrl) {
			allProducts = sampleProducts;
			renderProducts();
			return;
		}

		try {
			const client = new ConvexHttpClient(convexUrl);
			const products = await client.query('products:list' as never, {} as never);
			allProducts = Array.isArray(products) && products.length > 0 ? products as Product[] : sampleProducts;
		} catch {
			allProducts = sampleProducts;
		}
		renderProducts();
	}

	searchInput?.addEventListener('input', renderProducts);
	categoryFilter?.addEventListener('change', renderProducts);
	countryFilter?.addEventListener('change', renderProducts);
	statusFilter?.addEventListener('change', renderProducts);

	loadProducts();
</script>
