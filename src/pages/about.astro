---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About | GABA" description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>About GABA</h1>
				<p class="tagline">Your gateway to Zimbabwe's digital ecosystem</p>
			</section>

			<section class="content">
				<h2>Our Mission</h2>
				<p>
					GABA is your central hub for staying connected with Zimbabwe's vibrant digital community.
					We aggregate blogs, news, projects, and local businesses to showcase the incredible talent
					and innovation coming out of Zimbabwe.
				</p>

				<h2>What We Feature</h2>
				<ul>
					<li><strong>Blog</strong> - Personal stories, tutorials, and insights from Zimbabwean developers and creators</li>
					<li><strong>News</strong> - Local tech news, business updates, and community events</li>
					<li><strong>Projects</strong> - A portfolio of web apps, mobile apps, and websites built by local talent</li>
					<li><strong>Business Directory</strong> - Discover local businesses and services across Zimbabwe</li>
				</ul>

				<h2>For Local Businesses</h2>
				<p>
					GABA's business directory helps local Zimbabwean businesses gain visibility. Whether you're
					a restaurant in Harare, a tech agency in Bulawayo, or a corner shop in Mutare, we're here
					to help connect you with customers.
				</p>

				<h2>Get Involved</h2>
				<p>
					Have a blog post to share? A project to showcase? A business to list? We'd love to hear
					from you. GABA is built with Astro and open source, making it easy to contribute.
				</p>

<div class="contact-cta">
				<p>Interested in contributing or listing your business?</p>
				<p class="powered-by">Powered by <a href="https://xalosoftware.com" target="_blank" class="xalo-link">XaloSoftware</a></p>
				<a href="mailto:hello@gaba.co.zw" class="btn">Get in Touch</a>
			</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 720px;
		margin: 0 auto;
		padding: 1em;
	}
	.hero {
		text-align: center;
		padding: 3em 0;
		border-bottom: 1px solid rgb(var(--gray-light));
		margin-bottom: 2em;
	}
	.hero h1 {
		font-size: 2.5em;
		margin-bottom: 0.5em;
		color: var(--zim-green);
	}
	.tagline {
		color: rgb(var(--gray));
		font-size: 1.2em;
	}
	.content h2 {
		color: var(--zim-green);
		margin-top: 2em;
		margin-bottom: 0.75em;
	}
	.content p {
		line-height: 1.8;
		color: rgb(var(--gray-dark));
	}
	.content ul {
		list-style: none;
		padding: 0;
	}
	.content li {
		padding: 0.75em 0;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.content li:last-child {
		border-bottom: none;
	}
	.content li strong {
		color: var(--zim-gold);
	}
	.contact-cta {
		text-align: center;
		padding: 2em;
		background: linear-gradient(135deg, var(--zim-green), #2d7a38);
		border-radius: 12px;
		margin-top: 3em;
		color: #fff;
	}
	.contact-cta p {
		margin-bottom: 1em;
		color: #fff;
	}
	.btn {
		display: inline-block;
		padding: 0.75em 2em;
		background: var(--zim-gold);
		color: #000;
		text-decoration: none;
		border-radius: 8px;
		font-weight: 600;
	}
	.btn:hover {
		background: #fff;
	}
	.powered-by {
		font-size: 0.9em;
		margin-top: 1em;
		color: rgba(255, 255, 255, 0.8);
	}
	.xalo-link {
		color: var(--zim-gold);
		text-decoration: none;
		font-weight: 600;
	}
	.xalo-link:hover {
		text-decoration: underline;
	}
</style>