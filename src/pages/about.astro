---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About | GABA" description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>About GABA</h1>
				<p class="tagline">African tech, on African terms</p>
			</section>

			<section class="content">
				<h2>Our Mission</h2>
				<p>
					GABA is a Product Hunt alternative for African tech, built for countries left out of the
					major discovery platforms. We start in Zimbabwe and index products, makers, drops, and
					stories across the continent.
				</p>

				<h2>What We Feature</h2>
				<ul>
					<li><strong>Best Products</strong> - Apps, AI tools, gadgets, SaaS products, fintech, and hardware</li>
					<li><strong>Drops</strong> - Weekly product launches and editorial picks</li>
					<li><strong>Stories</strong> - Maker stories, market context, and launch notes</li>
					<li><strong>Community</strong> - Discussion around products, problems, and local distribution</li>
					<li><strong>Advertise</strong> - Featured listings, jobs, and GABA Verified interest</li>
				</ul>

				<h2>For Makers</h2>
				<p>
					GABA helps African makers, startups, developers, and hardware builders get visibility.
					Whether you're launching a mobile app, an AI tool, a SaaS product, or a gadget prototype,
					we're here to help people discover what you're building.
				</p>

				<h2>Get Involved</h2>
				<p>
					Have a product to submit or a story to share? We want the problem, the maker, the country,
					and the people it helps. That context is the point.
				</p>

<div class="contact-cta">
				<p>Interested in contributing or submitting a product?</p>
				<p class="powered-by">Powered by <a href="https://xalosoftware.com" target="_blank" class="xalo-link">XaloSoftware</a></p>
				<a href="/vendor/products/new" class="btn">Submit a Product</a>
			</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 720px;
		margin: 0 auto;
		padding: 1em;
	}
	.hero {
		text-align: center;
		padding: 3em 0;
		border-bottom: 1px solid rgb(var(--gray-light));
		margin-bottom: 2em;
	}
	.hero h1 {
		font-size: 2.5em;
		margin-bottom: 0.5em;
		color: var(--zim-green);
	}
	.tagline {
		color: rgb(var(--gray));
		font-size: 1.2em;
	}
	.content h2 {
		color: var(--zim-green);
		margin-top: 2em;
		margin-bottom: 0.75em;
	}
	.content p {
		line-height: 1.8;
		color: rgb(var(--gray-dark));
	}
	.content ul {
		list-style: none;
		padding: 0;
	}
	.content li {
		padding: 0.75em 0;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.content li:last-child {
		border-bottom: none;
	}
	.content li strong {
		color: var(--zim-gold);
	}
	.contact-cta {
		text-align: center;
		padding: 2em;
		background: linear-gradient(135deg, var(--zim-green), #2d7a38);
		border-radius: 12px;
		margin-top: 3em;
		color: #fff;
	}
	.contact-cta p {
		margin-bottom: 1em;
		color: #fff;
	}
	.btn {
		display: inline-block;
		padding: 0.75em 2em;
		background: var(--zim-gold);
		color: #000;
		text-decoration: none;
		border-radius: 8px;
		font-weight: 600;
	}
	.btn:hover {
		background: #fff;
	}
	.powered-by {
		font-size: 0.9em;
		margin-top: 1em;
		color: rgba(255, 255, 255, 0.8);
	}
	.xalo-link {
		color: var(--zim-gold);
		text-decoration: none;
		font-weight: 600;
	}
	.xalo-link:hover {
		text-decoration: underline;
	}
</style>
