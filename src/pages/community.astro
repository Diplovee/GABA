---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Community | GABA" description="The GABA community for African tech makers and product people." />
	</head>
	<body>
		<Header />
		<main class="simple-page">
			<p class="eyebrow">Built by the left out, for the left out</p>
			<h1>Community</h1>
			<p class="lead">A practical room for African makers, operators, designers, and early users to discuss products, local problems, launches, and distribution.</p>
			<div class="panel-grid">
				<section>
					<h2>Maker Discussions</h2>
					<p>Launch feedback, product questions, and lessons from building in African markets.</p>
				</section>
				<section>
					<h2>Country Rooms</h2>
					<p>Zimbabwe-first spaces that can expand across Africa as the product index grows.</p>
				</section>
				<section>
					<h2>Early Users</h2>
					<p>A place for founders to find the first people willing to test and talk honestly.</p>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.simple-page {
		width: min(1180px, calc(100% - 3rem));
		max-width: none;
		padding: 4rem 0;
	}
	.eyebrow {
		margin: 0 0 0.8rem;
		color: var(--accent);
		font-size: 0.72rem;
		font-weight: 950;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}
	h1 {
		margin: 0;
		color: #0f172a;
		font-size: clamp(2.8rem, 7vw, 5rem);
		font-weight: 900;
		letter-spacing: -0.04em;
	}
	.lead {
		max-width: 760px;
		margin: 1rem 0 2rem;
		color: #475569;
		font-size: 1.08rem;
		line-height: 1.8;
	}
	.panel-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}
	.panel-grid section {
		border: 1px solid var(--ui-border);
		border-radius: 8px;
		background: white;
		padding: 1.25rem;
	}
	.panel-grid h2 {
		margin: 0 0 0.7rem;
		color: #0f172a;
		font-size: 0.9rem;
		font-weight: 950;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	.panel-grid p {
		margin: 0;
		color: #64748b;
		font-size: 0.92rem;
		line-height: 1.7;
	}
	@media (max-width: 760px) {
		.simple-page {
			width: min(100% - 1.5rem, 1180px);
		}
		.panel-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
