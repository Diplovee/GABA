---
const today = new Date();
---

<footer class="site-footer">
	<div class="footer-inner">
		<div>
			<div class="footer-brand">
				<span>GABA Products</span>
			</div>
			<p>
				Africa-first product discovery for the builders, markets, and countries left out of the major platforms.
			</p>
		</div>
		<div class="footer-links">
			<div>
				<h5>Discover</h5>
				<a href="/">Best Products</a>
				<a href="/news">Stories</a>
			</div>
			<div>
				<h5>Platform</h5>
				<a href="/vendor/products/new">Submit Product</a>
				<a href="/community">Community</a>
				<a href="/about">About GABA</a>
			</div>
		</div>
	</div>
	<div class="footer-bottom">
		<span>© {today.getFullYear()} GABA • HARARE BUILT</span>
		<span>AFRICAN TECH, ON AFRICAN TERMS</span>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--ui-border);
		background: white;
		padding: 3rem 0 2rem;
	}
	.footer-inner,
	.footer-bottom {
		width: min(1400px, calc(100% - 3rem));
		margin: 0 auto;
	}
	.footer-inner {
		display: flex;
		justify-content: space-between;
		gap: 3rem;
	}
	.footer-brand {
		display: inline-flex;
		align-items: center;
		margin-bottom: 1.3rem;
		color: #0f172a;
		font-size: 0.88rem;
		font-weight: 900;
		letter-spacing: -0.01em;
		text-transform: uppercase;
	}
	.site-footer p {
		max-width: 360px;
		margin: 0;
		color: #94a3b8;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.08em;
		line-height: 1.8;
		text-transform: uppercase;
	}
	.footer-links {
		display: flex;
		gap: clamp(2rem, 7vw, 5rem);
	}
	.footer-links div {
		display: grid;
		gap: 0.75rem;
	}
	.footer-links h5 {
		margin: 0 0 0.7rem;
		color: #0f172a;
		font-size: 10px;
		font-weight: 900;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}
	.footer-links a {
		color: #64748b;
		font-size: 11px;
		font-weight: 900;
		letter-spacing: 0.08em;
		text-decoration: none;
		text-transform: uppercase;
	}
	.footer-links a:hover {
		color: var(--accent);
	}
	.footer-bottom {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 3rem;
		padding-top: 1.6rem;
		border-top: 1px solid #f1f5f9;
		color: #cbd5e1;
		font-size: 10px;
		font-weight: 900;
		letter-spacing: 0.2em;
		text-transform: uppercase;
	}
	@media (max-width: 760px) {
		.footer-inner,
		.footer-bottom {
			width: min(100% - 1.5rem, 1400px);
		}
		.footer-inner,
		.footer-bottom,
		.footer-links {
			display: grid;
		}
	}
</style>
