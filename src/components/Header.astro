---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<nav class="main-nav" aria-label="Primary navigation">
		<div class="nav-inner">
			<a href="/" class="brand" aria-label={`${SITE_TITLE} home`}>
				<span>{SITE_TITLE}</span>
			</a>
			<div class="internal-links">
				<HeaderLink href="/">Best Products</HeaderLink>
				<HeaderLink href="/news">Stories</HeaderLink>
				<HeaderLink href="/community">Community</HeaderLink>
			</div>
			<div class="nav-actions">
				<form class="terminal-search" action="/">
					<span aria-hidden="true">⌕</span>
					<input name="q" type="search" placeholder="Search products..." />
					<kbd>CMD K</kbd>
				</form>
				<div class="profile-menu" id="profile-menu">
					<a href="/vendor/dashboard" class="profile-link" aria-label="Open profile menu" aria-haspopup="true" aria-expanded="false">
						<span class="profile-avatar" aria-hidden="true">T</span>
					</a>
					<div class="profile-dropdown" aria-label="Profile options">
						<a href="/vendor/dashboard?tab=profile">Profile</a>
						<a href="/vendor/dashboard?tab=products">My products</a>
						<a href="/vendor/dashboard?tab=settings">Settings</a>
						<a href="/vendor/dashboard?tab=api">API dashboard</a>
						<hr />
						<button type="button" id="header-logout-button">Logout</button>
					</div>
				</div>
				<a href="/vendor/products/new" class="request-btn">Submit Product</a>
			</div>
		</div>
	</nav>
</header>

<script>
	import { signOut } from '../lib/convexAuthClient';

	const profileMenu = document.getElementById('profile-menu');
	const profileLink = profileMenu?.querySelector('.profile-link') as HTMLAnchorElement | null;
	const logoutButton = document.getElementById('header-logout-button');

	const setExpanded = (expanded: boolean) => {
		profileLink?.setAttribute('aria-expanded', expanded ? 'true' : 'false');
	};

	profileMenu?.addEventListener('mouseenter', () => setExpanded(true));
	profileMenu?.addEventListener('mouseleave', () => setExpanded(false));
	profileLink?.addEventListener('focus', () => setExpanded(true));
	profileMenu?.querySelectorAll('a, button').forEach((item) => {
		item.addEventListener('blur', () => {
			window.setTimeout(() => {
				const active = document.activeElement;
				if (!profileMenu.contains(active)) {
					setExpanded(false);
				}
			}, 0);
		});
	});

	logoutButton?.addEventListener('click', async () => {
		await signOut();
		window.location.href = '/vendor';
	});
</script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
	}
	.nav-inner {
		width: min(1400px, calc(100% - 3rem));
		margin: 0 auto;
	}
	.main-nav {
		border-bottom: 1px solid var(--ui-border);
		background: rgba(255, 255, 255, 0.96);
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
		backdrop-filter: blur(12px);
	}
	.nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
		min-height: 64px;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		color: #0f172a;
		font-size: 1.25rem;
		font-weight: 900;
		letter-spacing: -0.02em;
		text-decoration: none;
		text-transform: uppercase;
	}
	.brand:hover {
		color: #0f172a;
	}
	.internal-links {
		display: flex;
		gap: 1.7rem;
		align-items: center;
		margin-right: auto;
	}
	.internal-links a {
		position: relative;
		color: #64748b;
		font-size: 11px;
		font-weight: 900;
		letter-spacing: 0.12em;
		text-decoration: none;
		text-transform: uppercase;
	}
	.internal-links a::after {
		content: '';
		position: absolute;
		bottom: -7px;
		left: 0;
		width: 0;
		height: 2px;
		background: var(--accent);
		transition: width 0.2s;
	}
	.internal-links a:hover,
	.internal-links a.active {
		color: #0f172a;
	}
	.internal-links a:hover::after,
	.internal-links a.active::after {
		width: 100%;
	}
	.nav-actions {
		display: flex;
		align-items: center;
		gap: 0.9rem;
	}
	.terminal-search {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		min-height: 34px;
		padding: 0 0.6rem;
		border: 1px solid var(--ui-border);
		border-radius: 4px;
		background: #f1f5f9;
		color: #94a3b8;
	}
	.terminal-search input {
		width: 160px;
		border: 0;
		outline: 0;
		background: transparent;
		color: #0f172a;
		font-size: 12px;
		font-weight: 700;
	}
	.terminal-search input::placeholder {
		color: #94a3b8;
		text-transform: capitalize;
	}
	kbd {
		padding: 0.1rem 0.25rem;
		border-radius: 3px;
		background: #e2e8f0;
		color: #64748b;
		font-size: 9px;
		font-weight: 900;
	}
	.profile-menu {
		position: relative;
	}
	.profile-link,
	.request-btn {
		font-size: 11px;
		font-weight: 900;
		letter-spacing: 0.08em;
		text-decoration: none;
		text-transform: uppercase;
	}
	.profile-link {
		display: inline-grid;
		width: 44px;
		height: 44px;
		place-items: center;
		border: 0;
		border-radius: 10px;
		background: transparent;
		overflow: hidden;
		color: #475569;
	}
	.profile-avatar {
		display: grid;
		width: 100%;
		height: 100%;
		place-items: center;
		background:
			radial-gradient(circle at 36% 36%, rgba(139, 92, 246, 0.55), transparent 35%),
			linear-gradient(145deg, #4f46e5 0%, #6366f1 45%, #a78bfa 100%);
		color: white;
		font-size: 1.45rem;
		font-weight: 900;
		letter-spacing: 0;
		text-transform: uppercase;
		box-shadow: inset 0 -8px 20px rgba(79, 70, 229, 0.18);
	}
	.profile-link:hover {
		filter: saturate(1.05) brightness(1.02);
	}
	.profile-dropdown {
		position: absolute;
		top: calc(100% + 0.6rem);
		right: 0;
		display: grid;
		min-width: 220px;
		padding: 0.8rem;
		border: 1px solid var(--ui-border);
		border-radius: 8px;
		background: white;
		box-shadow: 0 18px 42px rgba(15, 23, 42, 0.12);
		opacity: 0;
		pointer-events: none;
		transform: translateY(6px);
		transition: opacity 0.18s ease, transform 0.18s ease;
	}
	.profile-menu:hover .profile-dropdown,
	.profile-menu:focus-within .profile-dropdown {
		opacity: 1;
		pointer-events: auto;
		transform: translateY(0);
	}
	.profile-dropdown a,
	.profile-dropdown button {
		display: block;
		padding: 0.8rem 0.85rem;
		border: 0;
		background: transparent;
		color: #1e293b;
		font: inherit;
		font-size: 0.98rem;
		font-weight: 600;
		text-align: left;
		text-decoration: none;
		cursor: pointer;
	}
	.profile-dropdown a:hover,
	.profile-dropdown button:hover {
		background: #f8fafc;
	}
	.profile-dropdown hr {
		width: 100%;
		margin: 0.35rem 0;
		border: 0;
		border-top: 1px solid #dbe4f0;
	}
	.request-btn {
		padding: 0.65rem 1rem;
		border-radius: 4px;
		background: var(--accent);
		color: white;
	}
	.request-btn:hover {
		background: var(--accent-dark);
		color: white;
	}
	@media (max-width: 1120px) {
		.internal-links {
			display: none;
		}
	}
	@media (max-width: 760px) {
		.utility-inner,
		.nav-inner {
			width: min(100% - 1.5rem, 1400px);
		}
		.utility-right,
		.terminal-search {
			display: none;
		}
		.nav-inner {
			gap: 1rem;
		}
		.request-btn {
			padding-inline: 0.75rem;
		}
		.profile-dropdown {
			right: -0.4rem;
		}
	}
</style>
