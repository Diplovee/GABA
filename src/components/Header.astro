---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<nav class="main-nav" aria-label="Primary navigation">
		<div class="nav-inner">
			<a href="/" class="brand" aria-label={`${SITE_TITLE} home`}>
				<span class="brand-mark" aria-hidden="true">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="square" stroke-linejoin="miter">
						<path d="M12 2 2 7l10 5 10-5-10-5Z"></path>
						<path d="m2 12 10 5 10-5"></path>
						<path d="m2 17 10 5 10-5"></path>
					</svg>
				</span>
				<span>{SITE_TITLE}</span>
			</a>
			<div class="internal-links">
				<HeaderLink href="/">Best Products</HeaderLink>
				<HeaderLink href="/news">Stories</HeaderLink>
				<HeaderLink href="/community">Community</HeaderLink>
				<HeaderLink href="/advertise">Advertise</HeaderLink>
			</div>
			<div class="nav-actions">
				<form class="terminal-search" action="/">
					<span aria-hidden="true">⌕</span>
					<input name="q" type="search" placeholder="Search products..." />
					<kbd>CMD K</kbd>
				</form>
				<a href="/vendor" class="signin-link">Sign In</a>
				<a href="/vendor/products/new" class="request-btn">Submit Product</a>
			</div>
		</div>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
	}
	.nav-inner {
		width: min(1400px, calc(100% - 3rem));
		margin: 0 auto;
	}
	.main-nav {
		border-bottom: 1px solid var(--ui-border);
		background: rgba(255, 255, 255, 0.96);
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
		backdrop-filter: blur(12px);
	}
	.nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
		min-height: 64px;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		color: #0f172a;
		font-size: 1.25rem;
		font-weight: 900;
		letter-spacing: -0.02em;
		text-decoration: none;
		text-transform: uppercase;
	}
	.brand:hover {
		color: #0f172a;
	}
	.brand-mark {
		display: grid;
		width: 32px;
		height: 32px;
		place-items: center;
		background: #0f172a;
		color: white;
	}
	.internal-links {
		display: flex;
		gap: 1.7rem;
		align-items: center;
		margin-right: auto;
	}
	.internal-links a {
		position: relative;
		color: #64748b;
		font-size: 11px;
		font-weight: 900;
		letter-spacing: 0.12em;
		text-decoration: none;
		text-transform: uppercase;
	}
	.internal-links a::after {
		content: '';
		position: absolute;
		bottom: -7px;
		left: 0;
		width: 0;
		height: 2px;
		background: var(--accent);
		transition: width 0.2s;
	}
	.internal-links a:hover,
	.internal-links a.active {
		color: #0f172a;
	}
	.internal-links a:hover::after,
	.internal-links a.active::after {
		width: 100%;
	}
	.nav-actions {
		display: flex;
		align-items: center;
		gap: 0.9rem;
	}
	.terminal-search {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		min-height: 34px;
		padding: 0 0.6rem;
		border: 1px solid var(--ui-border);
		border-radius: 4px;
		background: #f1f5f9;
		color: #94a3b8;
	}
	.terminal-search input {
		width: 160px;
		border: 0;
		outline: 0;
		background: transparent;
		color: #0f172a;
		font-size: 12px;
		font-weight: 700;
	}
	.terminal-search input::placeholder {
		color: #94a3b8;
		text-transform: capitalize;
	}
	kbd {
		padding: 0.1rem 0.25rem;
		border-radius: 3px;
		background: #e2e8f0;
		color: #64748b;
		font-size: 9px;
		font-weight: 900;
	}
	.signin-link,
	.request-btn {
		font-size: 11px;
		font-weight: 900;
		letter-spacing: 0.08em;
		text-decoration: none;
		text-transform: uppercase;
	}
	.signin-link {
		color: #64748b;
	}
	.request-btn {
		padding: 0.65rem 1rem;
		border-radius: 4px;
		background: var(--accent);
		color: white;
	}
	.request-btn:hover {
		background: var(--accent-dark);
		color: white;
	}
	@media (max-width: 1120px) {
		.internal-links {
			display: none;
		}
	}
	@media (max-width: 760px) {
		.utility-inner,
		.nav-inner {
			width: min(100% - 1.5rem, 1400px);
		}
		.utility-right,
		.terminal-search,
		.signin-link {
			display: none;
		}
		.nav-inner {
			gap: 1rem;
		}
		.request-btn {
			padding-inline: 0.75rem;
		}
	}
</style>
